    store64(p + PRACTICE_NAME_PTR, "Saturnalia");
    store64(p + PRACTICE_NAME_LEN, 10);
    store64(p + PRACTICE_CATEGORY, PRACTICE_FESTIVAL);
    store64(p + PRACTICE_FREQUENCY, FREQ_ANNUAL);
    store64(p + PRACTICE_SACRED, 1);
    hadara_set_practices(CID_ROMAN, ro_practices, 3);

    # --- Roman art forms ---
    var ro_arts = alloc(ART_FORM_SIZE * 3);
    a = ro_arts;
    store64(a + ART_FORM_NAME_PTR, "Mosaic");
    store64(a + ART_FORM_NAME_LEN, 6);
    store64(a + ART_FORM_MEDIUM, ART_VISUAL);
    a = ro_arts + ART_FORM_SIZE;
    store64(a + ART_FORM_NAME_PTR, "Aqueduct Engineering");
    store64(a + ART_FORM_NAME_LEN, 20);
    store64(a + ART_FORM_MEDIUM, ART_ARCHITECTURE);
    a = ro_arts + ART_FORM_SIZE * 2;
    store64(a + ART_FORM_NAME_PTR, "Latin Oratory");
    store64(a + ART_FORM_NAME_LEN, 13);
    store64(a + ART_FORM_MEDIUM, ART_ORAL_TRADITION);
    hadara_set_art_forms(CID_ROMAN, ro_arts, 3);

    # --- Roman figures ---
    var ro_figs = alloc(FIGURE_SIZE * 2);
    f = ro_figs;
    store64(f + FIGURE_NAME_PTR, "Julius Caesar");
    store64(f + FIGURE_NAME_LEN, 13);
    store64(f + FIGURE_ROLE_PTR, "General and statesman who transformed Republic into Empire");
    store64(f + FIGURE_ROLE_LEN, 58);
    store64(f + FIGURE_ERA_START, 0 - 100);
    store64(f + FIGURE_ERA_END, 0 - 44);
    f = ro_figs + FIGURE_SIZE;
    store64(f + FIGURE_NAME_PTR, "Virgil");
    store64(f + FIGURE_NAME_LEN, 6);
    store64(f + FIGURE_ROLE_PTR, "Poet of the Aeneid, foundational Latin literary tradition");
    store64(f + FIGURE_ROLE_LEN, 57);
    store64(f + FIGURE_ERA_START, 0 - 70);
    store64(f + FIGURE_ERA_END, 0 - 19);
    hadara_set_figures(CID_ROMAN, ro_figs, 2);

    return 0;
}

fn hadara_seed_subentities_1b() {
    var p = 0;
    var a = 0;
    var f = 0;
    var t = 0;
    var r = 0;
    var art = 0;

    # --- Additional relations ---

    # Greek influenced Roman — Boardman (1970--2005)
    var rels2 = alloc(RELATION_SIZE * 2);
    r = rels2;
    store64(r + RELATION_SOURCE, CID_GREEK);
    store64(r + RELATION_TARGET, CID_ROMAN);
    store64(r + RELATION_TYPE, REL_INFLUENCED);
    store64(r + RELATION_PERIOD_START, 0 - 300);
    store64(r + RELATION_PERIOD_END, 0 - 100);

    # Chinese influenced Japanese — Varley (2000)
    r = rels2 + RELATION_SIZE;
    store64(r + RELATION_SOURCE, CID_CHINESE);
    store64(r + RELATION_TARGET, CID_JAPANESE);
    store64(r + RELATION_TYPE, REL_INFLUENCED);
    store64(r + RELATION_PERIOD_START, 500);
    store64(r + RELATION_PERIOD_END, 900);

    hadara_set_relations(CID_GREEK, rels2, 1);
    hadara_set_relations(CID_ROMAN, rels2, 1);
    hadara_set_relations(CID_CHINESE, rels2 + RELATION_SIZE, 1);
    hadara_set_relations(CID_JAPANESE, rels2 + RELATION_SIZE, 1);

    # --- Syncretism and additional relations ---

    # Greek-Egyptian syncretism — Stewart & Shaw (1994): Hermes Trismegistus tradition
    # Mutual blending of Hellenic philosophy + Egyptian mystery tradition (c. 300 BCE - 200 CE)
    var rels3 = alloc(RELATION_SIZE * 3);
    r = rels3;
    store64(r + RELATION_SOURCE, CID_GREEK);
    store64(r + RELATION_TARGET, CID_EGYPTIAN);
    store64(r + RELATION_TYPE, REL_SYNCRETIZED);
    store64(r + RELATION_PERIOD_START, 0 - 300);
    store64(r + RELATION_PERIOD_END, 200);

    # Vedic-Chinese exchange via Silk Road Buddhism — Curtin (1984), Hansen (2012)
    r = rels3 + RELATION_SIZE;
    store64(r + RELATION_SOURCE, CID_VEDIC);
    store64(r + RELATION_TARGET, CID_CHINESE);
    store64(r + RELATION_TYPE, REL_EXCHANGED);
    store64(r + RELATION_PERIOD_START, 0 - 100);
    store64(r + RELATION_PERIOD_END, 800);

    # Roman absorbed Greek — Boardman (1970--2005): cultural absorption post-146 BCE
    r = rels3 + RELATION_SIZE * 2;
    store64(r + RELATION_SOURCE, CID_GREEK);
    store64(r + RELATION_TARGET, CID_ROMAN);
    store64(r + RELATION_TYPE, REL_ABSORBED);
    store64(r + RELATION_PERIOD_START, 0 - 146);
    store64(r + RELATION_PERIOD_END, 0 - 30);

    # Build composite relation arrays for cultures with multiple relations.
    # Each record built fresh (no cross-function references).

    # Egyptian: influence→Greek + syncretism↔Greek
    var eg_rels = alloc(RELATION_SIZE * 2);
    r = eg_rels;
    store64(r + RELATION_SOURCE, CID_EGYPTIAN);
    store64(r + RELATION_TARGET, CID_GREEK);
    store64(r + RELATION_TYPE, REL_INFLUENCED);
    store64(r + RELATION_PERIOD_START, 0 - 600);
    store64(r + RELATION_PERIOD_END, 0 - 300);
    r = eg_rels + RELATION_SIZE;
    store64(r + RELATION_SOURCE, CID_GREEK);
    store64(r + RELATION_TARGET, CID_EGYPTIAN);
    store64(r + RELATION_TYPE, REL_SYNCRETIZED);
    store64(r + RELATION_PERIOD_START, 0 - 300);
    store64(r + RELATION_PERIOD_END, 200);
    hadara_set_relations(CID_EGYPTIAN, eg_rels, 2);

    # Greek: influence→Roman + syncretism↔Egyptian + absorbed→Roman
    var gr_rels = alloc(RELATION_SIZE * 3);
    r = gr_rels;
    store64(r + RELATION_SOURCE, CID_GREEK);
    store64(r + RELATION_TARGET, CID_ROMAN);
    store64(r + RELATION_TYPE, REL_INFLUENCED);
    store64(r + RELATION_PERIOD_START, 0 - 300);
    store64(r + RELATION_PERIOD_END, 0 - 100);
    r = gr_rels + RELATION_SIZE;
    store64(r + RELATION_SOURCE, CID_GREEK);
    store64(r + RELATION_TARGET, CID_EGYPTIAN);
    store64(r + RELATION_TYPE, REL_SYNCRETIZED);
    store64(r + RELATION_PERIOD_START, 0 - 300);
    store64(r + RELATION_PERIOD_END, 200);
    r = gr_rels + RELATION_SIZE * 2;
    store64(r + RELATION_SOURCE, CID_GREEK);
    store64(r + RELATION_TARGET, CID_ROMAN);
    store64(r + RELATION_TYPE, REL_ABSORBED);
    store64(r + RELATION_PERIOD_START, 0 - 146);
    store64(r + RELATION_PERIOD_END, 0 - 30);
    hadara_set_relations(CID_GREEK, gr_rels, 3);

    # Roman: influence from Greek + absorbed from Greek
    var ro_rels = alloc(RELATION_SIZE * 2);
    r = ro_rels;
    store64(r + RELATION_SOURCE, CID_GREEK);
    store64(r + RELATION_TARGET, CID_ROMAN);
    store64(r + RELATION_TYPE, REL_INFLUENCED);
    store64(r + RELATION_PERIOD_START, 0 - 300);
    store64(r + RELATION_PERIOD_END, 0 - 100);
    r = ro_rels + RELATION_SIZE;
    store64(r + RELATION_SOURCE, CID_GREEK);
    store64(r + RELATION_TARGET, CID_ROMAN);
    store64(r + RELATION_TYPE, REL_ABSORBED);
    store64(r + RELATION_PERIOD_START, 0 - 146);
    store64(r + RELATION_PERIOD_END, 0 - 30);
    hadara_set_relations(CID_ROMAN, ro_rels, 2);

    # Vedic: exchange with Chinese
    var ve_rel = alloc(RELATION_SIZE);
    r = ve_rel;
    store64(r + RELATION_SOURCE, CID_VEDIC);
    store64(r + RELATION_TARGET, CID_CHINESE);
    store64(r + RELATION_TYPE, REL_EXCHANGED);
    store64(r + RELATION_PERIOD_START, 0 - 100);
    store64(r + RELATION_PERIOD_END, 800);
    hadara_set_relations(CID_VEDIC, ve_rel, 1);

    # Chinese: influence→Japanese + exchange with Vedic
    var ch_rels = alloc(RELATION_SIZE * 2);
    r = ch_rels;
    store64(r + RELATION_SOURCE, CID_CHINESE);
    store64(r + RELATION_TARGET, CID_JAPANESE);
    store64(r + RELATION_TYPE, REL_INFLUENCED);
    store64(r + RELATION_PERIOD_START, 500);
    store64(r + RELATION_PERIOD_END, 900);
    r = ch_rels + RELATION_SIZE;
    store64(r + RELATION_SOURCE, CID_VEDIC);
    store64(r + RELATION_TARGET, CID_CHINESE);
    store64(r + RELATION_TYPE, REL_EXCHANGED);
    store64(r + RELATION_PERIOD_START, 0 - 100);
    store64(r + RELATION_PERIOD_END, 800);
    hadara_set_relations(CID_CHINESE, ch_rels, 2);

    # --- West African figure — Levtzion & Pouwels (2000), Niane (1965) ---
    var wa_figs = alloc(FIGURE_SIZE * 2);
    f = wa_figs;
    store64(f + FIGURE_NAME_PTR, "Sundiata Keita");
    store64(f + FIGURE_NAME_LEN, 14);
    store64(f + FIGURE_ROLE_PTR, "Founded Mali Empire, codified Manden Charter");
    store64(f + FIGURE_ROLE_LEN, 45);
    store64(f + FIGURE_ERA_START, 1217);
    store64(f + FIGURE_ERA_END, 1255);
    f = wa_figs + FIGURE_SIZE;
    store64(f + FIGURE_NAME_PTR, "Mansa Musa");
    store64(f + FIGURE_NAME_LEN, 10);
    store64(f + FIGURE_ROLE_PTR, "Richest person in history, patronized Timbuktu scholarship");
    store64(f + FIGURE_ROLE_LEN, 58);
    store64(f + FIGURE_ERA_START, 1280);
    store64(f + FIGURE_ERA_END, 1337);
    hadara_set_figures(CID_WESTAFRICAN, wa_figs, 2);

    # --- Region, language, script for existing cultures ---
    # Daniels & Bright (1996) for scripts, Campbell (2021) for languages

    hadara_set_region(CID_EGYPTIAN, "North Africa", 12);
    hadara_set_language(CID_EGYPTIAN, "Egyptian", 8);
    hadara_set_script(CID_EGYPTIAN, "Hieroglyphic", 12);

    hadara_set_region(CID_PERSIAN, "West Asia", 9);
    hadara_set_language(CID_PERSIAN, "Farsi", 5);
    hadara_set_script(CID_PERSIAN, "Perso-Arabic", 12);

    hadara_set_region(CID_VEDIC, "South Asia", 10);
    hadara_set_language(CID_VEDIC, "Sanskrit", 8);
    hadara_set_script(CID_VEDIC, "Devanagari", 10);

    hadara_set_region(CID_GREEK, "Mediterranean", 13);
    hadara_set_language(CID_GREEK, "Ancient Greek", 12);
    hadara_set_script(CID_GREEK, "Greek alphabet", 14);

    hadara_set_region(CID_JAPANESE, "East Asia", 9);
    hadara_set_language(CID_JAPANESE, "Japanese", 8);
    hadara_set_script(CID_JAPANESE, "Kanji/Kana", 10);

    hadara_set_region(CID_WESTAFRICAN, "West Africa", 11);
    hadara_set_language(CID_WESTAFRICAN, "Manding", 7);
    hadara_set_script(CID_WESTAFRICAN, "N'Ko", 4);

    hadara_set_region(CID_SCOTTISH, "British Isles", 13);
    hadara_set_language(CID_SCOTTISH, "Scottish Gaelic", 15);
    hadara_set_script(CID_SCOTTISH, "Latin", 5);

    hadara_set_region(CID_NORSE, "Scandinavia", 11);
    hadara_set_language(CID_NORSE, "Old Norse", 9);
    hadara_set_script(CID_NORSE, "Runic", 5);

    hadara_set_region(CID_ABORIGINAL, "Australia", 9);
    hadara_set_language(CID_ABORIGINAL, "Pama-Nyungan", 12);
    # No single script — oral tradition culture

    hadara_set_region(CID_HIPHOP, "North America", 13);
    hadara_set_language(CID_HIPHOP, "English", 7);
    hadara_set_script(CID_HIPHOP, "Latin", 5);

    hadara_set_region(CID_MAYA, "Mesoamerica", 11);
    hadara_set_language(CID_MAYA, "Mayan", 5);
    hadara_set_script(CID_MAYA, "Maya glyphs", 11);

    hadara_set_region(CID_CHINESE, "East Asia", 9);
    hadara_set_language(CID_CHINESE, "Chinese", 7);
    hadara_set_script(CID_CHINESE, "Hanzi", 5);

    hadara_set_region(CID_ROMAN, "Mediterranean", 13);
    hadara_set_language(CID_ROMAN, "Latin", 5);
    hadara_set_script(CID_ROMAN, "Latin alphabet", 14);

    # ================================================================
    # High-priority new cultures (P-1 audit findings)
    # ================================================================

    # 13: Arab/Islamic — Hourani (1991): 7th century CE, continuous
    var arab = hadara_add("Arab-Islamic", 12, CULTURE_ACTIVE, 622, 0);
    hadara_set_endonym(CID_ARAB, "Arabi", 5);
    hadara_set_region(CID_ARAB, "West Asia, North Africa", 23);
    hadara_set_language(CID_ARAB, "Arabic", 6);
    hadara_set_script(CID_ARAB, "Arabic", 6);

    # 14: Korean — Eckert et al. (1990): Three Kingdoms period c. 57 BCE, continuous
    var korean = hadara_add("Korean", 6, CULTURE_ACTIVE, 0 - 57, 0);
    hadara_set_endonym(CID_KOREAN, "Hanguk", 6);
    hadara_set_region(CID_KOREAN, "East Asia", 9);
    hadara_set_language(CID_KOREAN, "Korean", 6);
    hadara_set_script(CID_KOREAN, "Hangul", 6);

    # 15: Tibetan — Samuel (1993): Tibetan Empire 7th c., Buddhist from 8th c.
    var tibetan = hadara_add("Tibetan", 7, CULTURE_ACTIVE, 627, 0);
    hadara_set_endonym(CID_TIBETAN, "Bod", 3);
    hadara_set_region(CID_TIBETAN, "Central Asia", 12);
    hadara_set_language(CID_TIBETAN, "Tibetan", 7);
    hadara_set_script(CID_TIBETAN, "Tibetan", 7);

    # 16: Mesopotamian — Kramer (1963): Sumerian city-states c. 3500 BCE to 539 BCE
    var mesopotamian = hadara_add("Mesopotamian", 12, CULTURE_HISTORICAL, 0 - 3500, 0 - 539);
    hadara_set_endonym(CID_MESOPOTAMIAN, "Kiengi", 6);
    hadara_set_region(CID_MESOPOTAMIAN, "Near East", 9);
    hadara_set_language(CID_MESOPOTAMIAN, "Sumerian", 8);
    hadara_set_script(CID_MESOPOTAMIAN, "Cuneiform", 9);

    # 17: Mongol — Weatherford (2004): steppe culture from antiquity, Empire 1206 CE
    var mongol = hadara_add("Mongol", 6, CULTURE_ACTIVE, 0 - 200, 0);
    hadara_set_endonym(CID_MONGOL, "Mongol", 6);
    hadara_set_region(CID_MONGOL, "Central Asia", 12);
    hadara_set_language(CID_MONGOL, "Mongolian", 9);
    hadara_set_script(CID_MONGOL, "Mongolian", 9);

    # 18: Jewish/Hebrew — Seltzer (1980): Israelite emergence c. 1200 BCE, continuous
    var jewish = hadara_add("Jewish", 6, CULTURE_ACTIVE, 0 - 1200, 0);
    hadara_set_endonym(CID_JEWISH, "Yehudi", 6);
    hadara_set_region(CID_JEWISH, "Near East, Diaspora", 19);
    hadara_set_language(CID_JEWISH, "Hebrew", 6);
    hadara_set_script(CID_JEWISH, "Hebrew", 6);

    # 19: Byzantine — Mango (1980): 330 CE (Constantinople) to 1453 CE (Ottoman conquest)
    var byzantine = hadara_add("Byzantine", 9, CULTURE_HISTORICAL, 330, 1453);
    hadara_set_endonym(CID_BYZANTINE, "Romaioi", 7);
    hadara_set_region(CID_BYZANTINE, "Eastern Mediterranean", 21);
    hadara_set_language(CID_BYZANTINE, "Greek", 5);
    hadara_set_script(CID_BYZANTINE, "Greek alphabet", 14);

    # 20: Polynesian — Howe (2006): Lapita expansion c. 1500 BCE, continuous
    var polynesian = hadara_add("Polynesian", 10, CULTURE_ACTIVE, 0 - 1500, 0);
    hadara_set_region(CID_POLYNESIAN, "Pacific Islands", 15);
    hadara_set_language(CID_POLYNESIAN, "Proto-Polynesian", 16);
    # Oral tradition culture — no indigenous script

    # ================================================================
    # Medium-priority cultures (Phase 4a — toward 50 target)
    # ================================================================

    # 21: Aztec/Mexica — Townsend (2009): 1325 CE (Tenochtitlan) to 1521 CE
    var aztec = hadara_add("Aztec", 5, CULTURE_HISTORICAL, 1325, 1521);
    hadara_set_endonym(aztec, "Mexica", 6);
    hadara_set_region(CID_AZTEC, "Mesoamerica", 11);
    hadara_set_language(CID_AZTEC, "Nahuatl", 7);
    hadara_set_script(CID_AZTEC, "Aztec pictographs", 17);
    hadara_set_display(CID_AZTEC, 9, 6, 3, 5);

    # 22: Inca/Quechua — D'Altroy (2014): 1438 CE empire, Quechua culture continuous
    var inca = hadara_add("Inca-Quechua", 12, CULTURE_ACTIVE, 0 - 2000, 0);
    hadara_set_endonym(inca, "Tawantinsuyu", 12);
    hadara_set_region(CID_INCA, "South America", 13);
    hadara_set_language(CID_INCA, "Quechua", 7);
    hadara_set_display(CID_INCA, 8, 5, 2, 4);

    # 23: Ottoman/Turkish — Finkel (2007): 1299 CE to 1922 CE (empire), Turkish culture continuous
    var ottoman = hadara_add("Turkish-Ottoman", 15, CULTURE_ACTIVE, 1299, 0);
    hadara_set_region(CID_OTTOMAN, "West Asia, Southeast Europe", 27);
    hadara_set_language(CID_OTTOMAN, "Turkish", 7);
    hadara_set_script(CID_OTTOMAN, "Latin alphabet", 14);
    hadara_set_display(CID_OTTOMAN, 7, 6, 5, 6);

    # 24: Khmer — Higham (2001): Angkor period 802 CE, Khmer culture continuous
    var khmer = hadara_add("Khmer", 5, CULTURE_ACTIVE, 802, 0);
    hadara_set_region(CID_KHMER, "Southeast Asia", 14);
    hadara_set_language(CID_KHMER, "Khmer", 5);
    hadara_set_script(CID_KHMER, "Khmer script", 12);
    hadara_set_display(CID_KHMER, 7, 5, 3, 4);

    # 25: Swahili — Nurse & Spear (1985): East African coast from c. 100 CE
    var swahili = hadara_add("Swahili", 7, CULTURE_ACTIVE, 100, 0);
    hadara_set_region(CID_SWAHILI, "East Africa", 11);
    hadara_set_language(CID_SWAHILI, "Kiswahili", 9);
    hadara_set_script(CID_SWAHILI, "Arabic/Latin", 12);
    hadara_set_display(CID_SWAHILI, 6, 7, 4, 6);

    # 26: Yoruba — Bascom (1969): pre-1000 CE origins, continuous
    var yoruba = hadara_add("Yoruba", 6, CULTURE_ACTIVE, 0 - 500, 0);
    hadara_set_endonym(CID_YORUBA, "Yoruba", 6);
    hadara_set_region(CID_YORUBA, "West Africa", 11);
    hadara_set_language(CID_YORUBA, "Yoruba", 6);
    hadara_set_script(CID_YORUBA, "Latin alphabet", 14);
    hadara_set_display(CID_YORUBA, 6, 8, 4, 6);

    # 27: Berber/Amazigh — Brett & Fentress (1996): ancient, continuous
    var amazigh = hadara_add("Amazigh", 7, CULTURE_ACTIVE, 0 - 3000, 0);
    hadara_set_endonym(CID_AMAZIGH, "Imazighen", 9);
    hadara_set_region(CID_AMAZIGH, "North Africa", 12);
    hadara_set_language(CID_AMAZIGH, "Tamazight", 9);
    hadara_set_script(CID_AMAZIGH, "Tifinagh", 8);
    hadara_set_display(CID_AMAZIGH, 5, 7, 5, 7);

    # 28: Inuit — Stern (2004): Arctic cultures, continuous from c. 1000 CE (Thule)
    var inuit = hadara_add("Inuit", 5, CULTURE_ACTIVE, 1000, 0);
    hadara_set_endonym(CID_INUIT, "Inuit", 5);
    hadara_set_region(CID_INUIT, "Arctic", 6);
    hadara_set_language(CID_INUIT, "Inuktitut", 9);
    hadara_set_script(CID_INUIT, "Syllabics", 9);
    hadara_set_display(CID_INUIT, 5, 5, 4, 5);

    # ================================================================
    # Sub-entities for new cultures (Phase 4a)
    # ================================================================

    # --- Arab/Islamic practices — Hourani (1991) ---
    var ar_practices = alloc(PRACTICE_SIZE * 3);
    p = ar_practices;
    store64(p + PRACTICE_NAME_PTR, "Salat");
    store64(p + PRACTICE_NAME_LEN, 5);
    store64(p + PRACTICE_CATEGORY, PRACTICE_RITUAL);
    store64(p + PRACTICE_FREQUENCY, FREQ_DAILY);
    store64(p + PRACTICE_SACRED, 1);
    p = ar_practices + PRACTICE_SIZE;
    store64(p + PRACTICE_NAME_PTR, "Hajj");
    store64(p + PRACTICE_NAME_LEN, 4);
    store64(p + PRACTICE_CATEGORY, PRACTICE_RITUAL);
    store64(p + PRACTICE_FREQUENCY, FREQ_LIFECYCLE);
    store64(p + PRACTICE_SACRED, 1);
    p = ar_practices + PRACTICE_SIZE * 2;
    store64(p + PRACTICE_NAME_PTR, "Ramadan Fast");
    store64(p + PRACTICE_NAME_LEN, 12);
    store64(p + PRACTICE_CATEGORY, PRACTICE_DIETARY);
    store64(p + PRACTICE_FREQUENCY, FREQ_ANNUAL);
    store64(p + PRACTICE_SACRED, 1);
    hadara_set_practices(CID_ARAB, ar_practices, 3);

    # --- Arab art forms ---
    var ar_arts = alloc(ART_FORM_SIZE * 3);
    a = ar_arts;
    store64(a + ART_FORM_NAME_PTR, "Arabic Calligraphy");
    store64(a + ART_FORM_NAME_LEN, 18);
    store64(a + ART_FORM_MEDIUM, ART_CALLIGRAPHY);
    a = ar_arts + ART_FORM_SIZE;
    store64(a + ART_FORM_NAME_PTR, "Geometric Tilework");
    store64(a + ART_FORM_NAME_LEN, 18);
    store64(a + ART_FORM_MEDIUM, ART_ARCHITECTURE);
    a = ar_arts + ART_FORM_SIZE * 2;
    store64(a + ART_FORM_NAME_PTR, "Qasida Poetry");
    store64(a + ART_FORM_NAME_LEN, 13);
    store64(a + ART_FORM_MEDIUM, ART_LITERATURE);
    hadara_set_art_forms(CID_ARAB, ar_arts, 3);

    # --- Arab figures ---
    var ar_figs = alloc(FIGURE_SIZE * 2);
    f = ar_figs;
    store64(f + FIGURE_NAME_PTR, "Ibn Khaldun");
    store64(f + FIGURE_NAME_LEN, 11);
    store64(f + FIGURE_ROLE_PTR, "Founded historiography and sociology, wrote Muqaddimah");
    store64(f + FIGURE_ROLE_LEN, 55);
    store64(f + FIGURE_ERA_START, 1332);
    store64(f + FIGURE_ERA_END, 1406);
    f = ar_figs + FIGURE_SIZE;
    store64(f + FIGURE_NAME_PTR, "Rumi");
    store64(f + FIGURE_NAME_LEN, 4);
    store64(f + FIGURE_ROLE_PTR, "Sufi mystic poet, Masnavi is foundational spiritual literature");
    store64(f + FIGURE_ROLE_LEN, 62);
    store64(f + FIGURE_ERA_START, 1207);
    store64(f + FIGURE_ERA_END, 1273);
    hadara_set_figures(CID_ARAB, ar_figs, 2);

    # --- Arab texts ---
    var ar_texts = alloc(TEXT_SIZE * 2);
    t = ar_texts;
    store64(t + TEXT_TITLE_PTR, "Quran");
    store64(t + TEXT_TITLE_LEN, 5);
    store64(t + TEXT_AUTHOR_PTR, 0);
    store64(t + TEXT_AUTHOR_LEN, 0);
    store64(t + TEXT_YEAR, 632);
    store64(t + TEXT_SACRED, 1);
    t = ar_texts + TEXT_SIZE;
    store64(t + TEXT_TITLE_PTR, "Muqaddimah");
    store64(t + TEXT_TITLE_LEN, 10);
    store64(t + TEXT_AUTHOR_PTR, "Ibn Khaldun");
    store64(t + TEXT_AUTHOR_LEN, 11);
    store64(t + TEXT_YEAR, 1377);
    store64(t + TEXT_SACRED, 0);
    hadara_set_texts(CID_ARAB, ar_texts, 2);

    # --- Korean practices — Eckert et al. (1990) ---
    var ko_practices = alloc(PRACTICE_SIZE * 2);
    p = ko_practices;
    store64(p + PRACTICE_NAME_PTR, "Jesa");
    store64(p + PRACTICE_NAME_LEN, 4);
    store64(p + PRACTICE_CATEGORY, PRACTICE_RITUAL);
    store64(p + PRACTICE_FREQUENCY, FREQ_ANNUAL);
    store64(p + PRACTICE_SACRED, 1);
    p = ko_practices + PRACTICE_SIZE;
    store64(p + PRACTICE_NAME_PTR, "Kimjang");
    store64(p + PRACTICE_NAME_LEN, 7);
    store64(p + PRACTICE_CATEGORY, PRACTICE_DIETARY);
    store64(p + PRACTICE_FREQUENCY, FREQ_ANNUAL);
    store64(p + PRACTICE_SACRED, 0);
    hadara_set_practices(CID_KOREAN, ko_practices, 2);

    # --- Korean art forms ---
    var ko_arts = alloc(ART_FORM_SIZE * 3);
    a = ko_arts;
    store64(a + ART_FORM_NAME_PTR, "Pansori");
    store64(a + ART_FORM_NAME_LEN, 7);
    store64(a + ART_FORM_MEDIUM, ART_ORAL_TRADITION);
    a = ko_arts + ART_FORM_SIZE;
    store64(a + ART_FORM_NAME_PTR, "Celadon Ceramics");
    store64(a + ART_FORM_NAME_LEN, 16);
    store64(a + ART_FORM_MEDIUM, ART_VISUAL);
    a = ko_arts + ART_FORM_SIZE * 2;
    store64(a + ART_FORM_NAME_PTR, "Hanok Architecture");
    store64(a + ART_FORM_NAME_LEN, 18);
    store64(a + ART_FORM_MEDIUM, ART_ARCHITECTURE);
    hadara_set_art_forms(CID_KOREAN, ko_arts, 3);

    # --- Jewish practices — Seltzer (1980) ---
    var je_practices = alloc(PRACTICE_SIZE * 3);
    p = je_practices;
    store64(p + PRACTICE_NAME_PTR, "Shabbat");
    store64(p + PRACTICE_NAME_LEN, 7);
    store64(p + PRACTICE_CATEGORY, PRACTICE_RITUAL);
    store64(p + PRACTICE_FREQUENCY, FREQ_WEEKLY);
    store64(p + PRACTICE_SACRED, 1);
    p = je_practices + PRACTICE_SIZE;
    store64(p + PRACTICE_NAME_PTR, "Passover Seder");
    store64(p + PRACTICE_NAME_LEN, 14);
    store64(p + PRACTICE_CATEGORY, PRACTICE_CEREMONY);
    store64(p + PRACTICE_FREQUENCY, FREQ_ANNUAL);
    store64(p + PRACTICE_SACRED, 1);
    p = je_practices + PRACTICE_SIZE * 2;
    store64(p + PRACTICE_NAME_PTR, "Kashrut");
    store64(p + PRACTICE_NAME_LEN, 7);
    store64(p + PRACTICE_CATEGORY, PRACTICE_DIETARY);
    store64(p + PRACTICE_FREQUENCY, FREQ_DAILY);
    store64(p + PRACTICE_SACRED, 1);
    hadara_set_practices(CID_JEWISH, je_practices, 3);

    # --- Jewish texts ---
    var je_texts = alloc(TEXT_SIZE * 2);
    t = je_texts;
    store64(t + TEXT_TITLE_PTR, "Torah");
    store64(t + TEXT_TITLE_LEN, 5);
    store64(t + TEXT_AUTHOR_PTR, 0);
    store64(t + TEXT_AUTHOR_LEN, 0);
    store64(t + TEXT_YEAR, 0 - 600);
    store64(t + TEXT_SACRED, 1);
    t = je_texts + TEXT_SIZE;
    store64(t + TEXT_TITLE_PTR, "Talmud");
    store64(t + TEXT_TITLE_LEN, 6);
    store64(t + TEXT_AUTHOR_PTR, 0);
    store64(t + TEXT_AUTHOR_LEN, 0);
    store64(t + TEXT_YEAR, 500);
    store64(t + TEXT_SACRED, 1);
    hadara_set_texts(CID_JEWISH, je_texts, 2);

    # --- Mesopotamian practices — Kramer (1963) ---
    var ms_practices = alloc(PRACTICE_SIZE * 2);
    p = ms_practices;
    store64(p + PRACTICE_NAME_PTR, "Akitu Festival");
    store64(p + PRACTICE_NAME_LEN, 14);
    store64(p + PRACTICE_CATEGORY, PRACTICE_FESTIVAL);
    store64(p + PRACTICE_FREQUENCY, FREQ_ANNUAL);
    store64(p + PRACTICE_SACRED, 1);
    p = ms_practices + PRACTICE_SIZE;
    store64(p + PRACTICE_NAME_PTR, "Temple Priesthood");
    store64(p + PRACTICE_NAME_LEN, 17);
    store64(p + PRACTICE_CATEGORY, PRACTICE_RITUAL);
    store64(p + PRACTICE_FREQUENCY, FREQ_DAILY);
    store64(p + PRACTICE_SACRED, 1);
    hadara_set_practices(CID_MESOPOTAMIAN, ms_practices, 2);

    # --- Mesopotamian art forms ---
    var ms_arts = alloc(ART_FORM_SIZE * 2);
    a = ms_arts;
    store64(a + ART_FORM_NAME_PTR, "Cuneiform Writing");
    store64(a + ART_FORM_NAME_LEN, 17);
    store64(a + ART_FORM_MEDIUM, ART_CALLIGRAPHY);
    a = ms_arts + ART_FORM_SIZE;
    store64(a + ART_FORM_NAME_PTR, "Ziggurat Architecture");
    store64(a + ART_FORM_NAME_LEN, 21);
    store64(a + ART_FORM_MEDIUM, ART_ARCHITECTURE);
    hadara_set_art_forms(CID_MESOPOTAMIAN, ms_arts, 2);

    # --- Mesopotamian texts ---
    var ms_texts = alloc(TEXT_SIZE * 2);
    t = ms_texts;
    store64(t + TEXT_TITLE_PTR, "Epic of Gilgamesh");
    store64(t + TEXT_TITLE_LEN, 17);
    store64(t + TEXT_AUTHOR_PTR, 0);
    store64(t + TEXT_AUTHOR_LEN, 0);
    store64(t + TEXT_YEAR, 0 - 2100);
    store64(t + TEXT_SACRED, 0);
    t = ms_texts + TEXT_SIZE;
    store64(t + TEXT_TITLE_PTR, "Code of Hammurabi");
    store64(t + TEXT_TITLE_LEN, 17);
    store64(t + TEXT_AUTHOR_PTR, "Hammurabi");
    store64(t + TEXT_AUTHOR_LEN, 9);
    store64(t + TEXT_YEAR, 0 - 1754);
    store64(t + TEXT_SACRED, 0);
    hadara_set_texts(CID_MESOPOTAMIAN, ms_texts, 2);

    # --- Polynesian practices — Howe (2006) ---
    var po_practices = alloc(PRACTICE_SIZE * 2);
    p = po_practices;
    store64(p + PRACTICE_NAME_PTR, "Wayfinding");
    store64(p + PRACTICE_NAME_LEN, 10);
    store64(p + PRACTICE_CATEGORY, PRACTICE_DAILY);
    store64(p + PRACTICE_FREQUENCY, FREQ_DAILY);
    store64(p + PRACTICE_SACRED, 1);
    p = po_practices + PRACTICE_SIZE;
    store64(p + PRACTICE_NAME_PTR, "Haka");
    store64(p + PRACTICE_NAME_LEN, 4);
    store64(p + PRACTICE_CATEGORY, PRACTICE_CEREMONY);
    store64(p + PRACTICE_FREQUENCY, FREQ_SPONTANEOUS);
    store64(p + PRACTICE_SACRED, 1);
    hadara_set_practices(CID_POLYNESIAN, po_practices, 2);

    # --- Polynesian art forms ---
    var po_arts = alloc(ART_FORM_SIZE * 2);
    a = po_arts;
    store64(a + ART_FORM_NAME_PTR, "Tatau");
    store64(a + ART_FORM_NAME_LEN, 5);
    store64(a + ART_FORM_MEDIUM, ART_VISUAL);
    a = po_arts + ART_FORM_SIZE;
    store64(a + ART_FORM_NAME_PTR, "Oral Navigation Chants");
    store64(a + ART_FORM_NAME_LEN, 22);
    store64(a + ART_FORM_MEDIUM, ART_ORAL_TRADITION);
    hadara_set_art_forms(CID_POLYNESIAN, po_arts, 2);

    # --- Tibetan practices — Samuel (1993) ---
    var ti_practices = alloc(PRACTICE_SIZE * 3);
    p = ti_practices;
    store64(p + PRACTICE_NAME_PTR, "Prostration");
    store64(p + PRACTICE_NAME_LEN, 11);
    store64(p + PRACTICE_CATEGORY, PRACTICE_RITUAL);
    store64(p + PRACTICE_FREQUENCY, FREQ_DAILY);
    store64(p + PRACTICE_SACRED, 1);
    p = ti_practices + PRACTICE_SIZE;
    store64(p + PRACTICE_NAME_PTR, "Mandala Offering");
    store64(p + PRACTICE_NAME_LEN, 16);
    store64(p + PRACTICE_CATEGORY, PRACTICE_CEREMONY);
    store64(p + PRACTICE_FREQUENCY, FREQ_SEASONAL);
    store64(p + PRACTICE_SACRED, 1);
    p = ti_practices + PRACTICE_SIZE * 2;
    store64(p + PRACTICE_NAME_PTR, "Butter Sculpture");
    store64(p + PRACTICE_NAME_LEN, 16);
    store64(p + PRACTICE_CATEGORY, PRACTICE_ART);
    store64(p + PRACTICE_FREQUENCY, FREQ_ANNUAL);
    store64(p + PRACTICE_SACRED, 1);
    hadara_set_practices(CID_TIBETAN, ti_practices, 3);

    # --- Tibetan art forms ---
    var ti_arts = alloc(ART_FORM_SIZE * 2);
    a = ti_arts;
    store64(a + ART_FORM_NAME_PTR, "Thangka Painting");
    store64(a + ART_FORM_NAME_LEN, 16);
    store64(a + ART_FORM_MEDIUM, ART_VISUAL);
    a = ti_arts + ART_FORM_SIZE;
    store64(a + ART_FORM_NAME_PTR, "Overtone Chanting");
    store64(a + ART_FORM_NAME_LEN, 17);
    store64(a + ART_FORM_MEDIUM, ART_MUSIC);
    hadara_set_art_forms(CID_TIBETAN, ti_arts, 2);

    # --- Tibetan texts ---
    var ti_texts = alloc(TEXT_SIZE * 1);
    t = ti_texts;
    store64(t + TEXT_TITLE_PTR, "Bardo Thodol");
    store64(t + TEXT_TITLE_LEN, 12);
    store64(t + TEXT_AUTHOR_PTR, "Padmasambhava");
    store64(t + TEXT_AUTHOR_LEN, 13);
    store64(t + TEXT_YEAR, 800);
    store64(t + TEXT_SACRED, 1);
    hadara_set_texts(CID_TIBETAN, ti_texts, 1);

    # --- Mongol practices — Weatherford (2004) ---
    var mo_practices = alloc(PRACTICE_SIZE * 2);
    p = mo_practices;
    store64(p + PRACTICE_NAME_PTR, "Naadam");
    store64(p + PRACTICE_NAME_LEN, 6);
    store64(p + PRACTICE_CATEGORY, PRACTICE_FESTIVAL);
    store64(p + PRACTICE_FREQUENCY, FREQ_ANNUAL);
    store64(p + PRACTICE_SACRED, 0);
    p = mo_practices + PRACTICE_SIZE;
    store64(p + PRACTICE_NAME_PTR, "Nomadic Herding");
    store64(p + PRACTICE_NAME_LEN, 15);
    store64(p + PRACTICE_CATEGORY, PRACTICE_DAILY);
    store64(p + PRACTICE_FREQUENCY, FREQ_DAILY);
    store64(p + PRACTICE_SACRED, 0);
    hadara_set_practices(CID_MONGOL, mo_practices, 2);

    # --- Mongol art forms ---
    var mo_arts = alloc(ART_FORM_SIZE * 2);
    a = mo_arts;
    store64(a + ART_FORM_NAME_PTR, "Khoomei");
    store64(a + ART_FORM_NAME_LEN, 7);
    store64(a + ART_FORM_MEDIUM, ART_MUSIC);
    a = mo_arts + ART_FORM_SIZE;
    store64(a + ART_FORM_NAME_PTR, "Epic of Jangar");
    store64(a + ART_FORM_NAME_LEN, 14);
    store64(a + ART_FORM_MEDIUM, ART_ORAL_TRADITION);
    hadara_set_art_forms(CID_MONGOL, mo_arts, 2);

    # --- Byzantine practices — Mango (1980) ---
    var by_practices = alloc(PRACTICE_SIZE * 2);
    p = by_practices;
    store64(p + PRACTICE_NAME_PTR, "Divine Liturgy");
    store64(p + PRACTICE_NAME_LEN, 14);
    store64(p + PRACTICE_CATEGORY, PRACTICE_RITUAL);
    store64(p + PRACTICE_FREQUENCY, FREQ_WEEKLY);
    store64(p + PRACTICE_SACRED, 1);
    p = by_practices + PRACTICE_SIZE;
    store64(p + PRACTICE_NAME_PTR, "Icon Veneration");
    store64(p + PRACTICE_NAME_LEN, 15);
    store64(p + PRACTICE_CATEGORY, PRACTICE_RITUAL);
    store64(p + PRACTICE_FREQUENCY, FREQ_DAILY);
    store64(p + PRACTICE_SACRED, 1);
    hadara_set_practices(CID_BYZANTINE, by_practices, 2);

    # --- Byzantine art forms ---
    var by_arts = alloc(ART_FORM_SIZE * 2);
    a = by_arts;
    store64(a + ART_FORM_NAME_PTR, "Icon Painting");
    store64(a + ART_FORM_NAME_LEN, 13);
    store64(a + ART_FORM_MEDIUM, ART_VISUAL);
    a = by_arts + ART_FORM_SIZE;
    store64(a + ART_FORM_NAME_PTR, "Hagia Sophia Style");
    store64(a + ART_FORM_NAME_LEN, 18);
    store64(a + ART_FORM_MEDIUM, ART_ARCHITECTURE);
    hadara_set_art_forms(CID_BYZANTINE, by_arts, 2);

    # --- Mesopotamian figures — Kramer (1963) ---
    var ms_figs = alloc(FIGURE_SIZE * 2);
    f = ms_figs;
    store64(f + FIGURE_NAME_PTR, "Hammurabi");
    store64(f + FIGURE_NAME_LEN, 9);
    store64(f + FIGURE_ROLE_PTR, "King of Babylon, codified one of earliest written law codes");
    store64(f + FIGURE_ROLE_LEN, 59);
    store64(f + FIGURE_ERA_START, 0 - 1810);
    store64(f + FIGURE_ERA_END, 0 - 1750);
    f = ms_figs + FIGURE_SIZE;
    store64(f + FIGURE_NAME_PTR, "Enheduanna");
    store64(f + FIGURE_NAME_LEN, 10);
    store64(f + FIGURE_ROLE_PTR, "First named author in history, high priestess and poet");
    store64(f + FIGURE_ROLE_LEN, 54);
    store64(f + FIGURE_ERA_START, 0 - 2285);
    store64(f + FIGURE_ERA_END, 0 - 2250);
    hadara_set_figures(CID_MESOPOTAMIAN, ms_figs, 2);

    # --- Korean figure — Eckert et al. (1990) ---
    var ko_figs = alloc(FIGURE_SIZE * 1);
    f = ko_figs;
    store64(f + FIGURE_NAME_PTR, "Sejong the Great");
    store64(f + FIGURE_NAME_LEN, 16);
    store64(f + FIGURE_ROLE_PTR, "Created Hangul alphabet, patron of science and culture");
    store64(f + FIGURE_ROLE_LEN, 55);
    store64(f + FIGURE_ERA_START, 1397);
    store64(f + FIGURE_ERA_END, 1450);
    hadara_set_figures(CID_KOREAN, ko_figs, 1);

    # --- Tibetan figure — Samuel (1993) ---
    var ti_figs = alloc(FIGURE_SIZE * 1);
    f = ti_figs;
    store64(f + FIGURE_NAME_PTR, "Padmasambhava");
    store64(f + FIGURE_NAME_LEN, 13);
    store64(f + FIGURE_ROLE_PTR, "Brought Vajrayana Buddhism to Tibet, founded Nyingma school");
    store64(f + FIGURE_ROLE_LEN, 60);
    store64(f + FIGURE_ERA_START, 700);
    store64(f + FIGURE_ERA_END, 800);
    hadara_set_figures(CID_TIBETAN, ti_figs, 1);

    # --- Mongol figure — Weatherford (2004) ---
    var mo_figs = alloc(FIGURE_SIZE * 1);
    f = mo_figs;
    store64(f + FIGURE_NAME_PTR, "Genghis Khan");
    store64(f + FIGURE_NAME_LEN, 12);
    store64(f + FIGURE_ROLE_PTR, "Unified Mongol tribes, created largest contiguous empire");
    store64(f + FIGURE_ROLE_LEN, 56);
    store64(f + FIGURE_ERA_START, 1162);
    store64(f + FIGURE_ERA_END, 1227);
    hadara_set_figures(CID_MONGOL, mo_figs, 1);

    # --- Byzantine figure — Mango (1980) ---
    var by_figs = alloc(FIGURE_SIZE * 1);
    f = by_figs;
    store64(f + FIGURE_NAME_PTR, "Justinian I");
    store64(f + FIGURE_NAME_LEN, 11);
    store64(f + FIGURE_ROLE_PTR, "Codified Roman law, built Hagia Sophia, reconquered West");
    store64(f + FIGURE_ROLE_LEN, 56);
    store64(f + FIGURE_ERA_START, 482);
    store64(f + FIGURE_ERA_END, 565);
    hadara_set_figures(CID_BYZANTINE, by_figs, 1);

    # --- Jewish figures — Seltzer (1980) ---
    var je_figs = alloc(FIGURE_SIZE * 2);
    f = je_figs;
    store64(f + FIGURE_NAME_PTR, "Moses");
    store64(f + FIGURE_NAME_LEN, 5);
    store64(f + FIGURE_ROLE_PTR, "Prophet and lawgiver, led Exodus, received Torah at Sinai");
    store64(f + FIGURE_ROLE_LEN, 57);
    store64(f + FIGURE_ERA_START, 0 - 1300);
    store64(f + FIGURE_ERA_END, 0 - 1200);
    f = je_figs + FIGURE_SIZE;
    store64(f + FIGURE_NAME_PTR, "Maimonides");
    store64(f + FIGURE_NAME_LEN, 10);
    store64(f + FIGURE_ROLE_PTR, "Philosopher, codified Jewish law in Mishneh Torah");
    store64(f + FIGURE_ROLE_LEN, 49);
    store64(f + FIGURE_ERA_START, 1138);
    store64(f + FIGURE_ERA_END, 1204);
    hadara_set_figures(CID_JEWISH, je_figs, 2);

    # ================================================================
    # Cultures 29-38: push toward 50 + subculture wiring
    # ================================================================

    # 29: Maori — Howe (2006): Polynesian settlers c. 1300 CE, continuous
    var maori = hadara_add("Maori", 5, CULTURE_ACTIVE, 1300, 0);
    hadara_set_endonym(CID_MAORI, "Tangata Whenua", 14);
    hadara_set_region(CID_MAORI, "Aotearoa", 8);
    hadara_set_language(CID_MAORI, "Te Reo Maori", 12);
    hadara_set_script(CID_MAORI, "Latin alphabet", 14);
    hadara_set_display(CID_MAORI, 7, 8, 4, 7);

    # 30: Sikh — McLeod (1997): founded 1469 CE, continuous
    var sikh = hadara_add("Sikh", 4, CULTURE_ACTIVE, 1469, 0);
    hadara_set_endonym(CID_SIKH, "Khalsa", 6);
    hadara_set_region(CID_SIKH, "South Asia", 10);
    hadara_set_language(CID_SIKH, "Punjabi", 7);
    hadara_set_script(CID_SIKH, "Gurmukhi", 8);
    hadara_set_display(CID_SIKH, 6, 7, 5, 8);

    # 31: Ethiopian/Ge'ez — Henze (2000): Aksumite roots 100 CE, continuous
    var ethiopian = hadara_add("Ethiopian", 9, CULTURE_ACTIVE, 100, 0);
    hadara_set_endonym(CID_ETHIOPIAN, "Habesha", 7);
    hadara_set_region(CID_ETHIOPIAN, "East Africa", 11);
    hadara_set_language(CID_ETHIOPIAN, "Amharic", 7);
    hadara_set_script(CID_ETHIOPIAN, "Ge'ez", 5);
    hadara_set_display(CID_ETHIOPIAN, 7, 6, 3, 5);

    # 32: Tamil — Zvelebil (1973): Sangam period c. 300 BCE, continuous
    var tamil = hadara_add("Tamil", 5, CULTURE_ACTIVE, 0 - 300, 0);
    hadara_set_endonym(CID_TAMIL, "Tamizh", 6);
    hadara_set_region(CID_TAMIL, "South Asia", 10);
    hadara_set_language(CID_TAMIL, "Tamil", 5);
    hadara_set_script(CID_TAMIL, "Tamil script", 12);
    hadara_set_display(CID_TAMIL, 7, 7, 5, 6);

    # 33: Javanese — Ricklefs (2001): Hindu-Buddhist period c. 400 CE, continuous
    var javanese = hadara_add("Javanese", 8, CULTURE_ACTIVE, 400, 0);
    hadara_set_region(CID_JAVANESE, "Southeast Asia", 14);
    hadara_set_language(CID_JAVANESE, "Javanese", 8);
    hadara_set_script(CID_JAVANESE, "Javanese script", 15);
    hadara_set_display(CID_JAVANESE, 8, 5, 3, 3);

    # 34: Armenian — Hovannisian (1997): Urartu roots c. 600 BCE, continuous
    var armenian = hadara_add("Armenian", 8, CULTURE_ACTIVE, 0 - 600, 0);
    hadara_set_endonym(CID_ARMENIAN, "Hay", 3);
    hadara_set_region(CID_ARMENIAN, "West Asia", 9);
    hadara_set_language(CID_ARMENIAN, "Armenian", 8);
    hadara_set_script(CID_ARMENIAN, "Armenian alphabet", 17);
    hadara_set_display(CID_ARMENIAN, 6, 7, 6, 7);

    # 35: Romani — Hancock (2002): diaspora from 11th c., continuous
    var romani = hadara_add("Romani", 6, CULTURE_ACTIVE, 1000, 0);
    hadara_set_endonym(CID_ROMANI, "Roma", 4);
    hadara_set_region(CID_ROMANI, "Europe, Diaspora", 16);
    hadara_set_language(CID_ROMANI, "Romani", 6);
    hadara_set_display(CID_ROMANI, 3, 9, 6, 7);

    # 36: Basque — Collins (1990): pre-Indo-European, continuous
    var basque = hadara_add("Basque", 6, CULTURE_ACTIVE, 0 - 3000, 0);
    hadara_set_endonym(CID_BASQUE, "Euskaldun", 9);
    hadara_set_region(CID_BASQUE, "Western Europe", 14);
    hadara_set_language(CID_BASQUE, "Euskara", 7);
    hadara_set_script(CID_BASQUE, "Latin alphabet", 14);
    hadara_set_display(CID_BASQUE, 5, 7, 7, 8);

    # 37: Haudenosaunee — Fenton (1998): Iroquois Confederacy c. 1142 CE
    var haudenosaunee = hadara_add("Haudenosaunee", 13, CULTURE_ACTIVE, 1142, 0);
    hadara_set_region(CID_HAUDENOSAUNEE, "North America", 13);
    hadara_set_language(CID_HAUDENOSAUNEE, "Mohawk", 6);
    hadara_set_display(CID_HAUDENOSAUNEE, 7, 6, 4, 6);

    # 38: East Coast Hip-Hop — subculture of Hip-Hop (#9)
    var eastcoast = hadara_add("East Coast Hip-Hop", 18, CULTURE_ACTIVE, 1973, 0);
    hadara_set_region(CID_EASTCOAST, "North America", 13);
    hadara_set_language(CID_EASTCOAST, "English", 7);
    hadara_set_display(CID_EASTCOAST, 2, 9, 8, 9);

    return 0;
}

fn hadara_seed_subentities_2() {
    var p = 0;
    var a = 0;
    var f = 0;
    var t = 0;
    var art = 0;

    # --- Sub-entities for cultures 29-38 ---

    # Maori practices — Howe (2006)
    var mr_practices = alloc(PRACTICE_SIZE * 2);
    p = mr_practices;
    store64(p + PRACTICE_NAME_PTR, "Haka");
    store64(p + PRACTICE_NAME_LEN, 4);
    store64(p + PRACTICE_CATEGORY, PRACTICE_CEREMONY);
    store64(p + PRACTICE_FREQUENCY, FREQ_SPONTANEOUS);
    store64(p + PRACTICE_SACRED, 1);
    p = mr_practices + PRACTICE_SIZE;
    store64(p + PRACTICE_NAME_PTR, "Powhiri");
    store64(p + PRACTICE_NAME_LEN, 7);
    store64(p + PRACTICE_CATEGORY, PRACTICE_CEREMONY);
    store64(p + PRACTICE_FREQUENCY, FREQ_SPONTANEOUS);
    store64(p + PRACTICE_SACRED, 1);
    hadara_set_practices(CID_MAORI, mr_practices, 2);

    var mr_arts = alloc(ART_FORM_SIZE * 2);
