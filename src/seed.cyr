    hadara_set_region(hiphop, "North America", 13);
    hadara_set_language(hiphop, "English", 7);
    hadara_set_script(hiphop, "Latin", 5);

    hadara_set_region(maya, "Mesoamerica", 11);
    hadara_set_language(maya, "Mayan", 5);
    hadara_set_script(maya, "Maya glyphs", 11);

    hadara_set_region(chinese, "East Asia", 9);
    hadara_set_language(chinese, "Chinese", 7);
    hadara_set_script(chinese, "Hanzi", 5);

    hadara_set_region(roman, "Mediterranean", 13);
    hadara_set_language(roman, "Latin", 5);
    hadara_set_script(roman, "Latin alphabet", 14);

    # ================================================================
    # High-priority new cultures (P-1 audit findings)
    # ================================================================

    # 13: Arab/Islamic — Hourani (1991): 7th century CE, continuous
    var arab = hadara_add("Arab-Islamic", 12, CULTURE_ACTIVE, 622, 0);
    hadara_set_endonym(arab, "Arabi", 5);
