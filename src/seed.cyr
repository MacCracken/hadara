# seed.cyr -- Pre-built culture data
#
# 29 cultures with verified dates, endonyms, and descriptions.
# All data sourced from academic references — see docs/sources/.
#
# Sources: Shaw (2000), Brosius (2006), Basham (1967), Boardman (1970--2005),
# Varley (2000), Iliffe (2007), Cunliffe (2018), Price (2019),
# Flood (2006), Chang (2005), Coe (2015), Stearns (2001), Boatwright (2012).
# Full bibliography: docs/sources/cultures.md

# --- Seed cultures ---
# Called after hadara_init() to populate the registry.

fn hadara_seed() {
    # 0: Egyptian — Shaw (2000): c. 3100 BCE (Narmer unification) to 641 CE (Arab conquest)
    var egyptian = hadara_add("Egyptian", 8, CULTURE_HISTORICAL, 0 - 3100, 641);
    hadara_set_endonym(egyptian, "Kemet", 5);

    # 1: Persian — Brosius (2006): Achaemenid founding 550 BCE, continuous to present
    var persian = hadara_add("Persian", 7, CULTURE_ACTIVE, 0 - 550, 0);
    hadara_set_endonym(persian, "Irani", 5);

    # 2: Vedic/Hindu — Basham (1967): Vedic period c. 1500 BCE, continuous
    var vedic = hadara_add("Vedic-Hindu", 10, CULTURE_ACTIVE, 0 - 1500, 0);
    hadara_set_endonym(vedic, "Sanatana Dharma", 15);

    # 3: Greek — Boardman (1970--2005): Archaic period c. 800 BCE to 146 BCE (Roman conquest)
    var greek = hadara_add("Ancient Greek", 12, CULTURE_HISTORICAL, 0 - 800, 0 - 146);
    hadara_set_endonym(greek, "Hellas", 6);

    # 4: Japanese — Varley (2000): Jomon/Yayoi transition c. 300 BCE, continuous
    var japanese = hadara_add("Japanese", 8, CULTURE_ACTIVE, 0 - 300, 0);
    hadara_set_endonym(japanese, "Nihon", 5);

    # 5: West African (Mali/Mande) — Iliffe (2007): Ghana Empire c. 300 CE, Mande continuous
    var westafrican = hadara_add("West African Mande", 18, CULTURE_ACTIVE, 300, 0);
    hadara_set_endonym(westafrican, "Manden", 6);

    # 6: Scottish/Gaelic — Cunliffe (2018): Kingdom of Alba 843 CE, Gaelic revival ongoing
    var scottish = hadara_add("Scottish Gaelic", 15, CULTURE_REVIVED, 843, 0);
    hadara_set_endonym(scottish, "Gaidheal", 8);

    # 7: Norse — Price (2019): Viking Age c. 793 CE to c. 1066 CE
    var norse = hadara_add("Norse", 5, CULTURE_HISTORICAL, 793, 1066);
    hadara_set_endonym(norse, "Norroen", 7);

    # 8: Aboriginal Australian — Flood (2006): 65,000+ years continuous
    var aboriginal = hadara_add("Aboriginal Australian", 21, CULTURE_ACTIVE, 0 - 65000, 0);

    # 9: Hip-Hop — Chang (2005): South Bronx, 1973, DJ Kool Herc's party
    var hiphop = hadara_add("Hip-Hop", 7, CULTURE_ACTIVE, 1973, 0);

    # 10: Maya — Coe (2015): Preclassic c. 2000 BCE, living Maya culture continuous
    var maya = hadara_add("Maya", 4, CULTURE_ACTIVE, 0 - 2000, 0);
    hadara_set_endonym(maya, "Mayab", 5);

    # 11: Chinese — Stearns (2001): Shang Dynasty c. 1600 BCE, continuous
    var chinese = hadara_add("Chinese", 7, CULTURE_ACTIVE, 0 - 1600, 0);
    hadara_set_endonym(chinese, "Zhonghua", 8);

    # 12: Roman — Boatwright (2012): 753 BCE founding to 476 CE (Western fall)
    var roman = hadara_add("Roman", 5, CULTURE_HISTORICAL, 0 - 753, 476);
    hadara_set_endonym(roman, "Roma", 4);

    # --- Seed practices ---

    # Hip-Hop practices — Chang (2005), Schloss (2009)
    var hp_practices = alloc(PRACTICE_SIZE * 4);
    var p = hp_practices;
    store64(p + PRACTICE_NAME_PTR, "Cypher");
    store64(p + PRACTICE_NAME_LEN, 6);
    store64(p + PRACTICE_CATEGORY, PRACTICE_ART);
    store64(p + PRACTICE_FREQUENCY, FREQ_SPONTANEOUS);
    store64(p + PRACTICE_SACRED, 0);
    p = hp_practices + PRACTICE_SIZE;
    store64(p + PRACTICE_NAME_PTR, "Block Party");
    store64(p + PRACTICE_NAME_LEN, 11);
    store64(p + PRACTICE_CATEGORY, PRACTICE_FESTIVAL);
    store64(p + PRACTICE_FREQUENCY, FREQ_SEASONAL);
    store64(p + PRACTICE_SACRED, 0);
    p = hp_practices + PRACTICE_SIZE * 2;
    store64(p + PRACTICE_NAME_PTR, "Breaking");
    store64(p + PRACTICE_NAME_LEN, 8);
    store64(p + PRACTICE_CATEGORY, PRACTICE_ART);
    store64(p + PRACTICE_FREQUENCY, FREQ_SPONTANEOUS);
    store64(p + PRACTICE_SACRED, 0);
    p = hp_practices + PRACTICE_SIZE * 3;
    store64(p + PRACTICE_NAME_PTR, "Graffiti Writing");
    store64(p + PRACTICE_NAME_LEN, 16);
    store64(p + PRACTICE_CATEGORY, PRACTICE_ART);
    store64(p + PRACTICE_FREQUENCY, FREQ_SPONTANEOUS);
    store64(p + PRACTICE_SACRED, 0);
    hadara_set_practices(hiphop, hp_practices, 4);

    # Vedic practices — Flood (1996)
    var v_practices = alloc(PRACTICE_SIZE * 3);
    p = v_practices;
    store64(p + PRACTICE_NAME_PTR, "Puja");
    store64(p + PRACTICE_NAME_LEN, 4);
    store64(p + PRACTICE_CATEGORY, PRACTICE_RITUAL);
    store64(p + PRACTICE_FREQUENCY, FREQ_DAILY);
    store64(p + PRACTICE_SACRED, 1);
    p = v_practices + PRACTICE_SIZE;
    store64(p + PRACTICE_NAME_PTR, "Yajna");
    store64(p + PRACTICE_NAME_LEN, 5);
    store64(p + PRACTICE_CATEGORY, PRACTICE_CEREMONY);
    store64(p + PRACTICE_FREQUENCY, FREQ_SEASONAL);
    store64(p + PRACTICE_SACRED, 1);
    p = v_practices + PRACTICE_SIZE * 2;
    store64(p + PRACTICE_NAME_PTR, "Yoga");
    store64(p + PRACTICE_NAME_LEN, 4);
    store64(p + PRACTICE_CATEGORY, PRACTICE_DAILY);
    store64(p + PRACTICE_FREQUENCY, FREQ_DAILY);
    store64(p + PRACTICE_SACRED, 1);
    hadara_set_practices(vedic, v_practices, 3);

    # Japanese practices — Varley (2000), Friday (1997)
    var j_practices = alloc(PRACTICE_SIZE * 3);
    p = j_practices;
    store64(p + PRACTICE_NAME_PTR, "Chado");
    store64(p + PRACTICE_NAME_LEN, 5);
    store64(p + PRACTICE_CATEGORY, PRACTICE_CEREMONY);
    store64(p + PRACTICE_FREQUENCY, FREQ_DAILY);
    store64(p + PRACTICE_SACRED, 0);
    p = j_practices + PRACTICE_SIZE;
    store64(p + PRACTICE_NAME_PTR, "Budo");
    store64(p + PRACTICE_NAME_LEN, 4);
    store64(p + PRACTICE_CATEGORY, PRACTICE_MARTIAL);
    store64(p + PRACTICE_FREQUENCY, FREQ_DAILY);
    store64(p + PRACTICE_SACRED, 1);
    p = j_practices + PRACTICE_SIZE * 2;
    store64(p + PRACTICE_NAME_PTR, "Matsuri");
    store64(p + PRACTICE_NAME_LEN, 7);
    store64(p + PRACTICE_CATEGORY, PRACTICE_FESTIVAL);
    store64(p + PRACTICE_FREQUENCY, FREQ_ANNUAL);
    store64(p + PRACTICE_SACRED, 1);
    hadara_set_practices(japanese, j_practices, 3);

    # --- Seed art forms ---

    # Hip-Hop art forms ��� Rose (1994), Fricke & Ahearn (2002)
    var hp_arts = alloc(ART_FORM_SIZE * 4);
    var a = hp_arts;
    store64(a + ART_FORM_NAME_PTR, "MCing");
    store64(a + ART_FORM_NAME_LEN, 5);
    store64(a + ART_FORM_MEDIUM, ART_MUSIC);
    a = hp_arts + ART_FORM_SIZE;
    store64(a + ART_FORM_NAME_PTR, "DJing");
    store64(a + ART_FORM_NAME_LEN, 5);
    store64(a + ART_FORM_MEDIUM, ART_MUSIC);
    a = hp_arts + ART_FORM_SIZE * 2;
    store64(a + ART_FORM_NAME_PTR, "Graffiti");
    store64(a + ART_FORM_NAME_LEN, 8);
    store64(a + ART_FORM_MEDIUM, ART_VISUAL);
    a = hp_arts + ART_FORM_SIZE * 3;
    store64(a + ART_FORM_NAME_PTR, "Breakdancing");
    store64(a + ART_FORM_NAME_LEN, 12);
    store64(a + ART_FORM_MEDIUM, ART_DANCE);
    hadara_set_art_forms(hiphop, hp_arts, 4);

    # Japanese art forms — Varley (2000), Nakata (1973)
    var j_arts = alloc(ART_FORM_SIZE * 4);
    a = j_arts;
    store64(a + ART_FORM_NAME_PTR, "Shodo");
    store64(a + ART_FORM_NAME_LEN, 5);
    store64(a + ART_FORM_MEDIUM, ART_CALLIGRAPHY);
    a = j_arts + ART_FORM_SIZE;
    store64(a + ART_FORM_NAME_PTR, "Noh");
    store64(a + ART_FORM_NAME_LEN, 3);
    store64(a + ART_FORM_MEDIUM, ART_THEATER);
    a = j_arts + ART_FORM_SIZE * 2;
    store64(a + ART_FORM_NAME_PTR, "Ukiyo-e");
    store64(a + ART_FORM_NAME_LEN, 7);
    store64(a + ART_FORM_MEDIUM, ART_VISUAL);
    a = j_arts + ART_FORM_SIZE * 3;
    store64(a + ART_FORM_NAME_PTR, "Gagaku");
    store64(a + ART_FORM_NAME_LEN, 6);
    store64(a + ART_FORM_MEDIUM, ART_MUSIC);
    hadara_set_art_forms(japanese, j_arts, 4);

    # West African art forms — Nettl et al. (1998--2002), Vansina (1985)
    var wa_arts = alloc(ART_FORM_SIZE * 3);
    a = wa_arts;
    store64(a + ART_FORM_NAME_PTR, "Griot Storytelling");
    store64(a + ART_FORM_NAME_LEN, 18);
    store64(a + ART_FORM_MEDIUM, ART_ORAL_TRADITION);
    a = wa_arts + ART_FORM_SIZE;
    store64(a + ART_FORM_NAME_PTR, "Djembe Drumming");
    store64(a + ART_FORM_NAME_LEN, 15);
    store64(a + ART_FORM_MEDIUM, ART_MUSIC);
    a = wa_arts + ART_FORM_SIZE * 2;
    store64(a + ART_FORM_NAME_PTR, "Mud Cloth Dyeing");
    store64(a + ART_FORM_NAME_LEN, 16);
    store64(a + ART_FORM_MEDIUM, ART_TEXTILE);
    hadara_set_art_forms(westafrican, wa_arts, 3);

    # --- Seed figures ---

    # Hip-Hop — Chang (2005), KRS-One (2009)
    var hp_figs = alloc(FIGURE_SIZE * 3);
    var f = hp_figs;
    store64(f + FIGURE_NAME_PTR, "DJ Kool Herc");
    store64(f + FIGURE_NAME_LEN, 12);
    store64(f + FIGURE_ROLE_PTR, "Originated hip-hop DJ style at 1520 Sedgwick Ave party");
    store64(f + FIGURE_ROLE_LEN, 55);
    store64(f + FIGURE_ERA_START, 1955);
    store64(f + FIGURE_ERA_END, 0);
    f = hp_figs + FIGURE_SIZE;
    store64(f + FIGURE_NAME_PTR, "KRS-One");
    store64(f + FIGURE_NAME_LEN, 7);
    store64(f + FIGURE_ROLE_PTR, "Founded Temple of Hiphop, codified hip-hop as culture");
    store64(f + FIGURE_ROLE_LEN, 54);
    store64(f + FIGURE_ERA_START, 1965);
    store64(f + FIGURE_ERA_END, 0);
    f = hp_figs + FIGURE_SIZE * 2;
    store64(f + FIGURE_NAME_PTR, "Afrika Bambaataa");
    store64(f + FIGURE_NAME_LEN, 16);
    store64(f + FIGURE_ROLE_PTR, "Founded Universal Zulu Nation, defined five elements");
    store64(f + FIGURE_ROLE_LEN, 52);
    store64(f + FIGURE_ERA_START, 1957);
    store64(f + FIGURE_ERA_END, 0);
    hadara_set_figures(hiphop, hp_figs, 3);

    # Persian — Brosius (2006), Boyce (2001)
    var pe_figs = alloc(FIGURE_SIZE * 2);
    f = pe_figs;
    store64(f + FIGURE_NAME_PTR, "Cyrus the Great");
    store64(f + FIGURE_NAME_LEN, 15);
    store64(f + FIGURE_ROLE_PTR, "Founded Achaemenid Empire, authored first human rights charter");
    store64(f + FIGURE_ROLE_LEN, 62);
    store64(f + FIGURE_ERA_START, 0 - 600);
    store64(f + FIGURE_ERA_END, 0 - 530);
    f = pe_figs + FIGURE_SIZE;
    store64(f + FIGURE_NAME_PTR, "Zoroaster");
    store64(f + FIGURE_NAME_LEN, 9);
    store64(f + FIGURE_ROLE_PTR, "Founded Zoroastrianism, composed the Gathas");
    store64(f + FIGURE_ROLE_LEN, 44);
    store64(f + FIGURE_ERA_START, 0 - 1500);
    store64(f + FIGURE_ERA_END, 0 - 1000);
    hadara_set_figures(persian, pe_figs, 2);

    # --- Seed texts ---

    # Vedic — Witzel (2003), Flood (1996)
    var v_texts = alloc(TEXT_SIZE * 2);
    var t = v_texts;
    store64(t + TEXT_TITLE_PTR, "Rigveda");
    store64(t + TEXT_TITLE_LEN, 7);
    store64(t + TEXT_AUTHOR_PTR, 0);
    store64(t + TEXT_AUTHOR_LEN, 0);
    store64(t + TEXT_YEAR, 0 - 1500);
    store64(t + TEXT_SACRED, 1);
    t = v_texts + TEXT_SIZE;
    store64(t + TEXT_TITLE_PTR, "Bhagavad Gita");
    store64(t + TEXT_TITLE_LEN, 13);
    store64(t + TEXT_AUTHOR_PTR, "Vyasa");
    store64(t + TEXT_AUTHOR_LEN, 5);
    store64(t + TEXT_YEAR, 0 - 200);
    store64(t + TEXT_SACRED, 1);
    hadara_set_texts(vedic, v_texts, 2);

    # Persian — Boyce (2001)
    var pe_texts = alloc(TEXT_SIZE * 1);
    t = pe_texts;
    store64(t + TEXT_TITLE_PTR, "Avesta");
    store64(t + TEXT_TITLE_LEN, 6);
    store64(t + TEXT_AUTHOR_PTR, "Zoroaster");
    store64(t + TEXT_AUTHOR_LEN, 9);
    store64(t + TEXT_YEAR, 0 - 1000);
    store64(t + TEXT_SACRED, 1);
    hadara_set_texts(persian, pe_texts, 1);

    # Norse — Larrington (2014)
    var n_texts = alloc(TEXT_SIZE * 2);
    t = n_texts;
    store64(t + TEXT_TITLE_PTR, "Poetic Edda");
    store64(t + TEXT_TITLE_LEN, 11);
    store64(t + TEXT_AUTHOR_PTR, 0);
    store64(t + TEXT_AUTHOR_LEN, 0);
    store64(t + TEXT_YEAR, 1270);
    store64(t + TEXT_SACRED, 1);
    t = n_texts + TEXT_SIZE;
    store64(t + TEXT_TITLE_PTR, "Prose Edda");
    store64(t + TEXT_TITLE_LEN, 10);
    store64(t + TEXT_AUTHOR_PTR, "Snorri Sturluson");
    store64(t + TEXT_AUTHOR_LEN, 16);
    store64(t + TEXT_YEAR, 1220);
    store64(t + TEXT_SACRED, 0);
    hadara_set_texts(norse, n_texts, 2);

    # Greek texts — Boardman (1970--2005)
    var gr_texts = alloc(TEXT_SIZE * 2);
    t = gr_texts;
    store64(t + TEXT_TITLE_PTR, "Iliad");
    store64(t + TEXT_TITLE_LEN, 5);
    store64(t + TEXT_AUTHOR_PTR, "Homer");
    store64(t + TEXT_AUTHOR_LEN, 5);
    store64(t + TEXT_YEAR, 0 - 750);
    store64(t + TEXT_SACRED, 0);
    t = gr_texts + TEXT_SIZE;
    store64(t + TEXT_TITLE_PTR, "Republic");
    store64(t + TEXT_TITLE_LEN, 8);
    store64(t + TEXT_AUTHOR_PTR, "Plato");
    store64(t + TEXT_AUTHOR_LEN, 5);
    store64(t + TEXT_YEAR, 0 - 375);
    store64(t + TEXT_SACRED, 0);
    hadara_set_texts(greek, gr_texts, 2);

    # Japanese texts — Keene (1976--1999), Philippi (1968)
    var jp_texts = alloc(TEXT_SIZE * 2);
    t = jp_texts;
    store64(t + TEXT_TITLE_PTR, "Kojiki");
    store64(t + TEXT_TITLE_LEN, 6);
    store64(t + TEXT_AUTHOR_PTR, "O no Yasumaro");
    store64(t + TEXT_AUTHOR_LEN, 13);
    store64(t + TEXT_YEAR, 712);
    store64(t + TEXT_SACRED, 1);
    t = jp_texts + TEXT_SIZE;
    store64(t + TEXT_TITLE_PTR, "Tale of Genji");
    store64(t + TEXT_TITLE_LEN, 13);
    store64(t + TEXT_AUTHOR_PTR, "Murasaki Shikibu");
    store64(t + TEXT_AUTHOR_LEN, 16);
    store64(t + TEXT_YEAR, 1000);
    store64(t + TEXT_SACRED, 0);
    hadara_set_texts(japanese, jp_texts, 2);

    # West African texts — Vansina (1985), Niane (1965)
    var wa_texts = alloc(TEXT_SIZE * 1);
    t = wa_texts;
    store64(t + TEXT_TITLE_PTR, "Sundiata Epic");
    store64(t + TEXT_TITLE_LEN, 13);
    store64(t + TEXT_AUTHOR_PTR, 0);
    store64(t + TEXT_AUTHOR_LEN, 0);
    store64(t + TEXT_YEAR, 1235);
    store64(t + TEXT_SACRED, 0);
    hadara_set_texts(westafrican, wa_texts, 1);

    # Maya texts — Coe (2015)
    var ma_texts = alloc(TEXT_SIZE * 1);
    t = ma_texts;
    store64(t + TEXT_TITLE_PTR, "Popol Vuh");
    store64(t + TEXT_TITLE_LEN, 9);
    store64(t + TEXT_AUTHOR_PTR, 0);
    store64(t + TEXT_AUTHOR_LEN, 0);
    store64(t + TEXT_YEAR, 1550);
    store64(t + TEXT_SACRED, 1);
    hadara_set_texts(maya, ma_texts, 1);

    # --- Seed artifacts ---

    # Egyptian artifacts — Shaw (2000), Prown (1982)
    var eg_artifacts = alloc(ARTIFACT_SIZE * 3);
    var art = eg_artifacts;
    store64(art + ARTIFACT_NAME_PTR, "Sarcophagus");
    store64(art + ARTIFACT_NAME_LEN, 11);
    store64(art + ARTIFACT_CATEGORY, ARTIFACT_CONTAINER);
    art = eg_artifacts + ARTIFACT_SIZE;
    store64(art + ARTIFACT_NAME_PTR, "Ankh Amulet");
    store64(art + ARTIFACT_NAME_LEN, 11);
    store64(art + ARTIFACT_CATEGORY, ARTIFACT_JEWELRY);
    art = eg_artifacts + ARTIFACT_SIZE * 2;
    store64(art + ARTIFACT_NAME_PTR, "Papyrus Scroll");
    store64(art + ARTIFACT_NAME_LEN, 14);
    store64(art + ARTIFACT_CATEGORY, ARTIFACT_TOOL);
    hadara_set_artifacts(egyptian, eg_artifacts, 3);

    # Japanese artifacts — Varley (2000)
    var jp_artifacts = alloc(ARTIFACT_SIZE * 3);
    art = jp_artifacts;
    store64(art + ARTIFACT_NAME_PTR, "Katana");
    store64(art + ARTIFACT_NAME_LEN, 6);
    store64(art + ARTIFACT_CATEGORY, ARTIFACT_WEAPON);
    art = jp_artifacts + ARTIFACT_SIZE;
    store64(art + ARTIFACT_NAME_PTR, "Kimono");
    store64(art + ARTIFACT_NAME_LEN, 6);
    store64(art + ARTIFACT_CATEGORY, ARTIFACT_CLOTHING);
    art = jp_artifacts + ARTIFACT_SIZE * 2;
    store64(art + ARTIFACT_NAME_PTR, "Torii Gate");
    store64(art + ARTIFACT_NAME_LEN, 10);
    store64(art + ARTIFACT_CATEGORY, ARTIFACT_ARCHITECTURE);
    hadara_set_artifacts(japanese, jp_artifacts, 3);

    # Norse artifacts — Price (2019)
    var no_artifacts = alloc(ARTIFACT_SIZE * 3);
    art = no_artifacts;
    store64(art + ARTIFACT_NAME_PTR, "Longship");
    store64(art + ARTIFACT_NAME_LEN, 8);
    store64(art + ARTIFACT_CATEGORY, ARTIFACT_TOOL);
    art = no_artifacts + ARTIFACT_SIZE;
    store64(art + ARTIFACT_NAME_PTR, "Mjolnir Pendant");
    store64(art + ARTIFACT_NAME_LEN, 15);
    store64(art + ARTIFACT_CATEGORY, ARTIFACT_JEWELRY);
    art = no_artifacts + ARTIFACT_SIZE * 2;
    store64(art + ARTIFACT_NAME_PTR, "Runestone");
    store64(art + ARTIFACT_NAME_LEN, 9);
    store64(art + ARTIFACT_CATEGORY, ARTIFACT_CRAFT);
    hadara_set_artifacts(norse, no_artifacts, 3);

    # Roman artifacts — Boatwright (2012)
    var ro_artifacts = alloc(ARTIFACT_SIZE * 3);
    art = ro_artifacts;
    store64(art + ARTIFACT_NAME_PTR, "Gladius");
    store64(art + ARTIFACT_NAME_LEN, 7);
    store64(art + ARTIFACT_CATEGORY, ARTIFACT_WEAPON);
    art = ro_artifacts + ARTIFACT_SIZE;
    store64(art + ARTIFACT_NAME_PTR, "Toga");
    store64(art + ARTIFACT_NAME_LEN, 4);
    store64(art + ARTIFACT_CATEGORY, ARTIFACT_CLOTHING);
    art = ro_artifacts + ARTIFACT_SIZE * 2;
    store64(art + ARTIFACT_NAME_PTR, "Amphora");
    store64(art + ARTIFACT_NAME_LEN, 7);
    store64(art + ARTIFACT_CATEGORY, ARTIFACT_CONTAINER);
    hadara_set_artifacts(roman, ro_artifacts, 3);

    # Hip-Hop artifacts — Chang (2005)
    var hp_artifacts = alloc(ARTIFACT_SIZE * 3);
    art = hp_artifacts;
    store64(art + ARTIFACT_NAME_PTR, "Turntable");
    store64(art + ARTIFACT_NAME_LEN, 9);
    store64(art + ARTIFACT_CATEGORY, ARTIFACT_INSTRUMENT);
    art = hp_artifacts + ARTIFACT_SIZE;
    store64(art + ARTIFACT_NAME_PTR, "Boombox");
    store64(art + ARTIFACT_NAME_LEN, 7);
    store64(art + ARTIFACT_CATEGORY, ARTIFACT_INSTRUMENT);
    art = hp_artifacts + ARTIFACT_SIZE * 2;
    store64(art + ARTIFACT_NAME_PTR, "Spray Can");
    store64(art + ARTIFACT_NAME_LEN, 9);
    store64(art + ARTIFACT_CATEGORY, ARTIFACT_TOOL);
    hadara_set_artifacts(hiphop, hp_artifacts, 3);

    # West African artifacts — Connah (2015)
    var wa_artifacts = alloc(ARTIFACT_SIZE * 3);
    art = wa_artifacts;
    store64(art + ARTIFACT_NAME_PTR, "Djembe");
    store64(art + ARTIFACT_NAME_LEN, 6);
    store64(art + ARTIFACT_CATEGORY, ARTIFACT_INSTRUMENT);
    art = wa_artifacts + ARTIFACT_SIZE;
    store64(art + ARTIFACT_NAME_PTR, "Bogolan Cloth");
    store64(art + ARTIFACT_NAME_LEN, 13);
    store64(art + ARTIFACT_CATEGORY, ARTIFACT_CLOTHING);
    art = wa_artifacts + ARTIFACT_SIZE * 2;
    store64(art + ARTIFACT_NAME_PTR, "Kora");
    store64(art + ARTIFACT_NAME_LEN, 4);
    store64(art + ARTIFACT_CATEGORY, ARTIFACT_INSTRUMENT);
    hadara_set_artifacts(westafrican, wa_artifacts, 3);

    # Chinese artifacts — Stearns (2001)
    var ch_artifacts = alloc(ARTIFACT_SIZE * 3);
    art = ch_artifacts;
    store64(art + ARTIFACT_NAME_PTR, "Jian Sword");
    store64(art + ARTIFACT_NAME_LEN, 10);
    store64(art + ARTIFACT_CATEGORY, ARTIFACT_WEAPON);
    art = ch_artifacts + ARTIFACT_SIZE;
    store64(art + ARTIFACT_NAME_PTR, "Porcelain Vessel");
    store64(art + ARTIFACT_NAME_LEN, 16);
    store64(art + ARTIFACT_CATEGORY, ARTIFACT_CRAFT);
    art = ch_artifacts + ARTIFACT_SIZE * 2;
    store64(art + ARTIFACT_NAME_PTR, "Hanfu");
    store64(art + ARTIFACT_NAME_LEN, 5);
    store64(art + ARTIFACT_CATEGORY, ARTIFACT_CLOTHING);
