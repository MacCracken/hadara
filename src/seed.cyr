# seed.cyr -- Pre-built culture data
#
# 13 cultures with verified dates, endonyms, and descriptions.
# All data sourced from academic references — see docs/sources/.
#
# Sources: Shaw (2000), Brosius (2006), Basham (1967), Boardman (1970--2005),
# Varley (2000), Iliffe (2007), Cunliffe (2018), Price (2019),
# Flood (2006), Chang (2005), Coe (2015), Stearns (2001), Boatwright (2012).
# Full bibliography: docs/sources/cultures.md

# --- Seed cultures ---
# Called after hadara_init() to populate the registry.

fn hadara_seed() {
    # 0: Egyptian — Shaw (2000): c. 3100 BCE (Narmer unification) to 641 CE (Arab conquest)
    var egyptian = hadara_add("Egyptian", 8, CULTURE_HISTORICAL, 0 - 3100, 641);
    hadara_set_endonym(egyptian, "Kemet", 5);

    # 1: Persian — Brosius (2006): Achaemenid founding 550 BCE, continuous to present
    var persian = hadara_add("Persian", 7, CULTURE_ACTIVE, 0 - 550, 0);
    hadara_set_endonym(persian, "Irani", 5);

    # 2: Vedic/Hindu — Basham (1967): Vedic period c. 1500 BCE, continuous
    var vedic = hadara_add("Vedic-Hindu", 10, CULTURE_ACTIVE, 0 - 1500, 0);
    hadara_set_endonym(vedic, "Sanatana Dharma", 15);

    # 3: Greek — Boardman (1970--2005): Archaic period c. 800 BCE to 146 BCE (Roman conquest)
    var greek = hadara_add("Ancient Greek", 12, CULTURE_HISTORICAL, 0 - 800, 0 - 146);
    hadara_set_endonym(greek, "Hellas", 6);

    # 4: Japanese — Varley (2000): Jomon/Yayoi transition c. 300 BCE, continuous
    var japanese = hadara_add("Japanese", 8, CULTURE_ACTIVE, 0 - 300, 0);
    hadara_set_endonym(japanese, "Nihon", 5);

    # 5: West African (Mali/Mande) — Iliffe (2007): Ghana Empire c. 300 CE, Mande continuous
    var westafrican = hadara_add("West African Mande", 18, CULTURE_ACTIVE, 300, 0);
    hadara_set_endonym(westafrican, "Manden", 6);

    # 6: Scottish/Gaelic — Cunliffe (2018): Kingdom of Alba 843 CE, Gaelic revival ongoing
    var scottish = hadara_add("Scottish Gaelic", 15, CULTURE_REVIVED, 843, 0);
    hadara_set_endonym(scottish, "Gaidheal", 8);

    # 7: Norse — Price (2019): Viking Age c. 793 CE to c. 1066 CE
    var norse = hadara_add("Norse", 5, CULTURE_HISTORICAL, 793, 1066);
    hadara_set_endonym(norse, "Norroen", 7);

    # 8: Aboriginal Australian — Flood (2006): 65,000+ years continuous
    var aboriginal = hadara_add("Aboriginal Australian", 21, CULTURE_ACTIVE, 0 - 65000, 0);

    # 9: Hip-Hop — Chang (2005): South Bronx, 1973, DJ Kool Herc's party
    var hiphop = hadara_add("Hip-Hop", 7, CULTURE_ACTIVE, 1973, 0);

    # 10: Maya — Coe (2015): Preclassic c. 2000 BCE, living Maya culture continuous
    var maya = hadara_add("Maya", 4, CULTURE_ACTIVE, 0 - 2000, 0);
    hadara_set_endonym(maya, "Mayab", 5);

    # 11: Chinese — Stearns (2001): Shang Dynasty c. 1600 BCE, continuous
    var chinese = hadara_add("Chinese", 7, CULTURE_ACTIVE, 0 - 1600, 0);
    hadara_set_endonym(chinese, "Zhonghua", 8);

    # 12: Roman — Boatwright (2012): 753 BCE founding to 476 CE (Western fall)
    var roman = hadara_add("Roman", 5, CULTURE_HISTORICAL, 0 - 753, 476);
    hadara_set_endonym(roman, "Roma", 4);

    # --- Seed practices ---

    # Hip-Hop practices — Chang (2005), Schloss (2009)
    var hp_practices = alloc(PRACTICE_SIZE * 4);
    var p = hp_practices;
    store64(p + PRACTICE_NAME_PTR, "Cypher");
    store64(p + PRACTICE_NAME_LEN, 6);
    store64(p + PRACTICE_CATEGORY, PRACTICE_ART);
    store64(p + PRACTICE_FREQUENCY, FREQ_SPONTANEOUS);
    store64(p + PRACTICE_SACRED, 0);
    p = hp_practices + PRACTICE_SIZE;
    store64(p + PRACTICE_NAME_PTR, "Block Party");
    store64(p + PRACTICE_NAME_LEN, 11);
    store64(p + PRACTICE_CATEGORY, PRACTICE_FESTIVAL);
    store64(p + PRACTICE_FREQUENCY, FREQ_SEASONAL);
    store64(p + PRACTICE_SACRED, 0);
    p = hp_practices + PRACTICE_SIZE * 2;
    store64(p + PRACTICE_NAME_PTR, "Breaking");
    store64(p + PRACTICE_NAME_LEN, 8);
    store64(p + PRACTICE_CATEGORY, PRACTICE_ART);
    store64(p + PRACTICE_FREQUENCY, FREQ_SPONTANEOUS);
    store64(p + PRACTICE_SACRED, 0);
    p = hp_practices + PRACTICE_SIZE * 3;
    store64(p + PRACTICE_NAME_PTR, "Graffiti Writing");
    store64(p + PRACTICE_NAME_LEN, 16);
    store64(p + PRACTICE_CATEGORY, PRACTICE_ART);
    store64(p + PRACTICE_FREQUENCY, FREQ_SPONTANEOUS);
    store64(p + PRACTICE_SACRED, 0);
    hadara_set_practices(hiphop, hp_practices, 4);

    # Vedic practices — Flood (1996)
    var v_practices = alloc(PRACTICE_SIZE * 3);
    p = v_practices;
    store64(p + PRACTICE_NAME_PTR, "Puja");
    store64(p + PRACTICE_NAME_LEN, 4);
    store64(p + PRACTICE_CATEGORY, PRACTICE_RITUAL);
    store64(p + PRACTICE_FREQUENCY, FREQ_DAILY);
    store64(p + PRACTICE_SACRED, 1);
    p = v_practices + PRACTICE_SIZE;
    store64(p + PRACTICE_NAME_PTR, "Yajna");
    store64(p + PRACTICE_NAME_LEN, 5);
    store64(p + PRACTICE_CATEGORY, PRACTICE_CEREMONY);
    store64(p + PRACTICE_FREQUENCY, FREQ_SEASONAL);
    store64(p + PRACTICE_SACRED, 1);
    p = v_practices + PRACTICE_SIZE * 2;
    store64(p + PRACTICE_NAME_PTR, "Yoga");
    store64(p + PRACTICE_NAME_LEN, 4);
    store64(p + PRACTICE_CATEGORY, PRACTICE_DAILY);
    store64(p + PRACTICE_FREQUENCY, FREQ_DAILY);
    store64(p + PRACTICE_SACRED, 1);
    hadara_set_practices(vedic, v_practices, 3);

    # Japanese practices — Varley (2000), Friday (1997)
    var j_practices = alloc(PRACTICE_SIZE * 3);
    p = j_practices;
    store64(p + PRACTICE_NAME_PTR, "Chado");
    store64(p + PRACTICE_NAME_LEN, 5);
    store64(p + PRACTICE_CATEGORY, PRACTICE_CEREMONY);
    store64(p + PRACTICE_FREQUENCY, FREQ_DAILY);
    store64(p + PRACTICE_SACRED, 0);
    p = j_practices + PRACTICE_SIZE;
    store64(p + PRACTICE_NAME_PTR, "Budo");
    store64(p + PRACTICE_NAME_LEN, 4);
    store64(p + PRACTICE_CATEGORY, PRACTICE_MARTIAL);
    store64(p + PRACTICE_FREQUENCY, FREQ_DAILY);
    store64(p + PRACTICE_SACRED, 1);
    p = j_practices + PRACTICE_SIZE * 2;
    store64(p + PRACTICE_NAME_PTR, "Matsuri");
    store64(p + PRACTICE_NAME_LEN, 7);
    store64(p + PRACTICE_CATEGORY, PRACTICE_FESTIVAL);
    store64(p + PRACTICE_FREQUENCY, FREQ_ANNUAL);
    store64(p + PRACTICE_SACRED, 1);
    hadara_set_practices(japanese, j_practices, 3);

    # --- Seed art forms ---

    # Hip-Hop art forms ��� Rose (1994), Fricke & Ahearn (2002)
    var hp_arts = alloc(ART_FORM_SIZE * 4);
    var a = hp_arts;
    store64(a + ART_FORM_NAME_PTR, "MCing");
    store64(a + ART_FORM_NAME_LEN, 5);
    store64(a + ART_FORM_MEDIUM, ART_MUSIC);
    a = hp_arts + ART_FORM_SIZE;
    store64(a + ART_FORM_NAME_PTR, "DJing");
    store64(a + ART_FORM_NAME_LEN, 5);
    store64(a + ART_FORM_MEDIUM, ART_MUSIC);
    a = hp_arts + ART_FORM_SIZE * 2;
    store64(a + ART_FORM_NAME_PTR, "Graffiti");
    store64(a + ART_FORM_NAME_LEN, 8);
    store64(a + ART_FORM_MEDIUM, ART_VISUAL);
    a = hp_arts + ART_FORM_SIZE * 3;
    store64(a + ART_FORM_NAME_PTR, "Breakdancing");
    store64(a + ART_FORM_NAME_LEN, 12);
    store64(a + ART_FORM_MEDIUM, ART_DANCE);
    hadara_set_art_forms(hiphop, hp_arts, 4);

    # Japanese art forms — Varley (2000), Nakata (1973)
    var j_arts = alloc(ART_FORM_SIZE * 4);
    a = j_arts;
    store64(a + ART_FORM_NAME_PTR, "Shodo");
    store64(a + ART_FORM_NAME_LEN, 5);
    store64(a + ART_FORM_MEDIUM, ART_CALLIGRAPHY);
    a = j_arts + ART_FORM_SIZE;
    store64(a + ART_FORM_NAME_PTR, "Noh");
    store64(a + ART_FORM_NAME_LEN, 3);
    store64(a + ART_FORM_MEDIUM, ART_THEATER);
    a = j_arts + ART_FORM_SIZE * 2;
    store64(a + ART_FORM_NAME_PTR, "Ukiyo-e");
    store64(a + ART_FORM_NAME_LEN, 7);
    store64(a + ART_FORM_MEDIUM, ART_VISUAL);
    a = j_arts + ART_FORM_SIZE * 3;
    store64(a + ART_FORM_NAME_PTR, "Gagaku");
    store64(a + ART_FORM_NAME_LEN, 6);
    store64(a + ART_FORM_MEDIUM, ART_MUSIC);
    hadara_set_art_forms(japanese, j_arts, 4);

    # West African art forms — Nettl et al. (1998--2002), Vansina (1985)
    var wa_arts = alloc(ART_FORM_SIZE * 3);
    a = wa_arts;
    store64(a + ART_FORM_NAME_PTR, "Griot Storytelling");
    store64(a + ART_FORM_NAME_LEN, 18);
    store64(a + ART_FORM_MEDIUM, ART_ORAL_TRADITION);
    a = wa_arts + ART_FORM_SIZE;
    store64(a + ART_FORM_NAME_PTR, "Djembe Drumming");
    store64(a + ART_FORM_NAME_LEN, 15);
    store64(a + ART_FORM_MEDIUM, ART_MUSIC);
    a = wa_arts + ART_FORM_SIZE * 2;
    store64(a + ART_FORM_NAME_PTR, "Mud Cloth Dyeing");
    store64(a + ART_FORM_NAME_LEN, 16);
    store64(a + ART_FORM_MEDIUM, ART_TEXTILE);
    hadara_set_art_forms(westafrican, wa_arts, 3);

    # --- Seed figures ---

    # Hip-Hop — Chang (2005), KRS-One (2009)
    var hp_figs = alloc(FIGURE_SIZE * 3);
    var f = hp_figs;
    store64(f + FIGURE_NAME_PTR, "DJ Kool Herc");
    store64(f + FIGURE_NAME_LEN, 12);
    store64(f + FIGURE_ROLE_PTR, "Originated hip-hop DJ style at 1520 Sedgwick Ave party");
    store64(f + FIGURE_ROLE_LEN, 55);
    store64(f + FIGURE_ERA_START, 1955);
    store64(f + FIGURE_ERA_END, 0);
    f = hp_figs + FIGURE_SIZE;
    store64(f + FIGURE_NAME_PTR, "KRS-One");
    store64(f + FIGURE_NAME_LEN, 7);
    store64(f + FIGURE_ROLE_PTR, "Founded Temple of Hiphop, codified hip-hop as culture");
    store64(f + FIGURE_ROLE_LEN, 54);
    store64(f + FIGURE_ERA_START, 1965);
    store64(f + FIGURE_ERA_END, 0);
    f = hp_figs + FIGURE_SIZE * 2;
    store64(f + FIGURE_NAME_PTR, "Afrika Bambaataa");
    store64(f + FIGURE_NAME_LEN, 16);
    store64(f + FIGURE_ROLE_PTR, "Founded Universal Zulu Nation, defined five elements");
    store64(f + FIGURE_ROLE_LEN, 52);
    store64(f + FIGURE_ERA_START, 1957);
    store64(f + FIGURE_ERA_END, 0);
    hadara_set_figures(hiphop, hp_figs, 3);

    # Persian — Brosius (2006), Boyce (2001)
    var pe_figs = alloc(FIGURE_SIZE * 2);
    f = pe_figs;
    store64(f + FIGURE_NAME_PTR, "Cyrus the Great");
    store64(f + FIGURE_NAME_LEN, 15);
    store64(f + FIGURE_ROLE_PTR, "Founded Achaemenid Empire, authored first human rights charter");
    store64(f + FIGURE_ROLE_LEN, 62);
    store64(f + FIGURE_ERA_START, 0 - 600);
    store64(f + FIGURE_ERA_END, 0 - 530);
    f = pe_figs + FIGURE_SIZE;
    store64(f + FIGURE_NAME_PTR, "Zoroaster");
    store64(f + FIGURE_NAME_LEN, 9);
    store64(f + FIGURE_ROLE_PTR, "Founded Zoroastrianism, composed the Gathas");
    store64(f + FIGURE_ROLE_LEN, 44);
    store64(f + FIGURE_ERA_START, 0 - 1500);
    store64(f + FIGURE_ERA_END, 0 - 1000);
    hadara_set_figures(persian, pe_figs, 2);

    # --- Seed texts ---

    # Vedic — Witzel (2003), Flood (1996)
    var v_texts = alloc(TEXT_SIZE * 2);
    var t = v_texts;
    store64(t + TEXT_TITLE_PTR, "Rigveda");
    store64(t + TEXT_TITLE_LEN, 7);
    store64(t + TEXT_AUTHOR_PTR, 0);
    store64(t + TEXT_AUTHOR_LEN, 0);
    store64(t + TEXT_YEAR, 0 - 1500);
    store64(t + TEXT_SACRED, 1);
    t = v_texts + TEXT_SIZE;
    store64(t + TEXT_TITLE_PTR, "Bhagavad Gita");
    store64(t + TEXT_TITLE_LEN, 13);
    store64(t + TEXT_AUTHOR_PTR, "Vyasa");
    store64(t + TEXT_AUTHOR_LEN, 5);
    store64(t + TEXT_YEAR, 0 - 200);
    store64(t + TEXT_SACRED, 1);
    hadara_set_texts(vedic, v_texts, 2);

    # Persian — Boyce (2001)
    var pe_texts = alloc(TEXT_SIZE * 1);
    t = pe_texts;
    store64(t + TEXT_TITLE_PTR, "Avesta");
    store64(t + TEXT_TITLE_LEN, 6);
    store64(t + TEXT_AUTHOR_PTR, "Zoroaster");
    store64(t + TEXT_AUTHOR_LEN, 9);
    store64(t + TEXT_YEAR, 0 - 1000);
    store64(t + TEXT_SACRED, 1);
    hadara_set_texts(persian, pe_texts, 1);

    # Norse — Larrington (2014)
    var n_texts = alloc(TEXT_SIZE * 2);
    t = n_texts;
    store64(t + TEXT_TITLE_PTR, "Poetic Edda");
    store64(t + TEXT_TITLE_LEN, 11);
    store64(t + TEXT_AUTHOR_PTR, 0);
    store64(t + TEXT_AUTHOR_LEN, 0);
    store64(t + TEXT_YEAR, 1270);
    store64(t + TEXT_SACRED, 1);
    t = n_texts + TEXT_SIZE;
    store64(t + TEXT_TITLE_PTR, "Prose Edda");
    store64(t + TEXT_TITLE_LEN, 10);
    store64(t + TEXT_AUTHOR_PTR, "Snorri Sturluson");
    store64(t + TEXT_AUTHOR_LEN, 16);
    store64(t + TEXT_YEAR, 1220);
    store64(t + TEXT_SACRED, 0);
    hadara_set_texts(norse, n_texts, 2);

    # --- Seed relations ---

    # Persian-Egyptian exchange — Briant (2002): 525-404 BCE
    var rels = alloc(RELATION_SIZE * 3);
    var r = rels;
    store64(r + RELATION_SOURCE, persian);
    store64(r + RELATION_TARGET, egyptian);
    store64(r + RELATION_TYPE, REL_EXCHANGED);
    store64(r + RELATION_PERIOD_START, 0 - 525);
    store64(r + RELATION_PERIOD_END, 0 - 404);

    # Greek influenced by Egyptian — Boardman (1970--2005)
    r = rels + RELATION_SIZE;
    store64(r + RELATION_SOURCE, egyptian);
    store64(r + RELATION_TARGET, greek);
    store64(r + RELATION_TYPE, REL_INFLUENCED);
    store64(r + RELATION_PERIOD_START, 0 - 600);
    store64(r + RELATION_PERIOD_END, 0 - 300);

    # Hip-Hop branched from West African (oral/musical tradition) — Rose (1994)
    r = rels + RELATION_SIZE * 2;
    store64(r + RELATION_SOURCE, westafrican);
    store64(r + RELATION_TARGET, hiphop);
    store64(r + RELATION_TYPE, REL_INFLUENCED);
    store64(r + RELATION_PERIOD_START, 1960);
    store64(r + RELATION_PERIOD_END, 1980);

    hadara_set_relations(persian, rels, 1);
    hadara_set_relations(egyptian, rels + RELATION_SIZE, 1);
    hadara_set_relations(hiphop, rels + RELATION_SIZE * 2, 1);

    # --- Egyptian practices — Shaw (2000), Eliade (1959) ---
    var eg_practices = alloc(PRACTICE_SIZE * 3);
    p = eg_practices;
    store64(p + PRACTICE_NAME_PTR, "Mummification");
    store64(p + PRACTICE_NAME_LEN, 13);
    store64(p + PRACTICE_CATEGORY, PRACTICE_RITUAL);
    store64(p + PRACTICE_FREQUENCY, FREQ_LIFECYCLE);
    store64(p + PRACTICE_SACRED, 1);
    p = eg_practices + PRACTICE_SIZE;
    store64(p + PRACTICE_NAME_PTR, "Temple Offering");
    store64(p + PRACTICE_NAME_LEN, 15);
    store64(p + PRACTICE_CATEGORY, PRACTICE_RITUAL);
    store64(p + PRACTICE_FREQUENCY, FREQ_DAILY);
    store64(p + PRACTICE_SACRED, 1);
    p = eg_practices + PRACTICE_SIZE * 2;
    store64(p + PRACTICE_NAME_PTR, "Wepet Renpet");
    store64(p + PRACTICE_NAME_LEN, 12);
    store64(p + PRACTICE_CATEGORY, PRACTICE_FESTIVAL);
    store64(p + PRACTICE_FREQUENCY, FREQ_ANNUAL);
    store64(p + PRACTICE_SACRED, 1);
    hadara_set_practices(egyptian, eg_practices, 3);

    # --- Egyptian art forms — Shaw (2000) ---
    var eg_arts = alloc(ART_FORM_SIZE * 3);
    a = eg_arts;
    store64(a + ART_FORM_NAME_PTR, "Hieroglyphic Writing");
    store64(a + ART_FORM_NAME_LEN, 20);
    store64(a + ART_FORM_MEDIUM, ART_CALLIGRAPHY);
    a = eg_arts + ART_FORM_SIZE;
    store64(a + ART_FORM_NAME_PTR, "Pyramid Architecture");
    store64(a + ART_FORM_NAME_LEN, 20);
    store64(a + ART_FORM_MEDIUM, ART_ARCHITECTURE);
    a = eg_arts + ART_FORM_SIZE * 2;
    store64(a + ART_FORM_NAME_PTR, "Tomb Painting");
    store64(a + ART_FORM_NAME_LEN, 13);
    store64(a + ART_FORM_MEDIUM, ART_VISUAL);
    hadara_set_art_forms(egyptian, eg_arts, 3);

    # --- Egyptian figures — Shaw (2000), Hornblower & Spawforth (2012) ---
    var eg_figs = alloc(FIGURE_SIZE * 2);
    f = eg_figs;
    store64(f + FIGURE_NAME_PTR, "Imhotep");
    store64(f + FIGURE_NAME_LEN, 7);
    store64(f + FIGURE_ROLE_PTR, "Architect of Step Pyramid, polymath deified as god of medicine");
    store64(f + FIGURE_ROLE_LEN, 62);
    store64(f + FIGURE_ERA_START, 0 - 2650);
    store64(f + FIGURE_ERA_END, 0 - 2600);
    f = eg_figs + FIGURE_SIZE;
    store64(f + FIGURE_NAME_PTR, "Hatshepsut");
    store64(f + FIGURE_NAME_LEN, 10);
    store64(f + FIGURE_ROLE_PTR, "Female pharaoh who expanded trade and commissioned great temples");
    store64(f + FIGURE_ROLE_LEN, 64);
    store64(f + FIGURE_ERA_START, 0 - 1507);
    store64(f + FIGURE_ERA_END, 0 - 1458);
    hadara_set_figures(egyptian, eg_figs, 2);

    # --- Egyptian texts — Faulkner (1969) ---
    var eg_texts = alloc(TEXT_SIZE * 2);
    t = eg_texts;
    store64(t + TEXT_TITLE_PTR, "Book of the Dead");
    store64(t + TEXT_TITLE_LEN, 16);
    store64(t + TEXT_AUTHOR_PTR, 0);
    store64(t + TEXT_AUTHOR_LEN, 0);
    store64(t + TEXT_YEAR, 0 - 1550);
    store64(t + TEXT_SACRED, 1);
    t = eg_texts + TEXT_SIZE;
    store64(t + TEXT_TITLE_PTR, "Pyramid Texts");
    store64(t + TEXT_TITLE_LEN, 13);
    store64(t + TEXT_AUTHOR_PTR, 0);
    store64(t + TEXT_AUTHOR_LEN, 0);
    store64(t + TEXT_YEAR, 0 - 2400);
    store64(t + TEXT_SACRED, 1);
    hadara_set_texts(egyptian, eg_texts, 2);

    # --- Greek practices — Boardman (1970--2005) ---
    var gr_practices = alloc(PRACTICE_SIZE * 3);
    p = gr_practices;
    store64(p + PRACTICE_NAME_PTR, "Olympic Games");
    store64(p + PRACTICE_NAME_LEN, 13);
    store64(p + PRACTICE_CATEGORY, PRACTICE_FESTIVAL);
    store64(p + PRACTICE_FREQUENCY, FREQ_SEASONAL);
    store64(p + PRACTICE_SACRED, 1);
    p = gr_practices + PRACTICE_SIZE;
    store64(p + PRACTICE_NAME_PTR, "Symposion");
    store64(p + PRACTICE_NAME_LEN, 9);
    store64(p + PRACTICE_CATEGORY, PRACTICE_SOCIAL);
    store64(p + PRACTICE_FREQUENCY, FREQ_WEEKLY);
    store64(p + PRACTICE_SACRED, 0);
    p = gr_practices + PRACTICE_SIZE * 2;
    store64(p + PRACTICE_NAME_PTR, "Mystery Rites");
    store64(p + PRACTICE_NAME_LEN, 13);
    store64(p + PRACTICE_CATEGORY, PRACTICE_RITUAL);
    store64(p + PRACTICE_FREQUENCY, FREQ_ANNUAL);
    store64(p + PRACTICE_SACRED, 1);
    hadara_set_practices(greek, gr_practices, 3);

    # --- Greek art forms ---
    var gr_arts = alloc(ART_FORM_SIZE * 3);
    a = gr_arts;
    store64(a + ART_FORM_NAME_PTR, "Tragedy");
    store64(a + ART_FORM_NAME_LEN, 7);
    store64(a + ART_FORM_MEDIUM, ART_THEATER);
    a = gr_arts + ART_FORM_SIZE;
    store64(a + ART_FORM_NAME_PTR, "Sculpture");
    store64(a + ART_FORM_NAME_LEN, 9);
    store64(a + ART_FORM_MEDIUM, ART_VISUAL);
    a = gr_arts + ART_FORM_SIZE * 2;
    store64(a + ART_FORM_NAME_PTR, "Epic Poetry");
    store64(a + ART_FORM_NAME_LEN, 11);
    store64(a + ART_FORM_MEDIUM, ART_LITERATURE);
    hadara_set_art_forms(greek, gr_arts, 3);

    # --- Greek figures ---
    var gr_figs = alloc(FIGURE_SIZE * 2);
    f = gr_figs;
    store64(f + FIGURE_NAME_PTR, "Socrates");
    store64(f + FIGURE_NAME_LEN, 8);
    store64(f + FIGURE_ROLE_PTR, "Founder of Western philosophy, dialectic method");
    store64(f + FIGURE_ROLE_LEN, 48);
    store64(f + FIGURE_ERA_START, 0 - 470);
    store64(f + FIGURE_ERA_END, 0 - 399);
    f = gr_figs + FIGURE_SIZE;
    store64(f + FIGURE_NAME_PTR, "Homer");
    store64(f + FIGURE_NAME_LEN, 5);
    store64(f + FIGURE_ROLE_PTR, "Composed Iliad and Odyssey, foundational epic tradition");
    store64(f + FIGURE_ROLE_LEN, 55);
    store64(f + FIGURE_ERA_START, 0 - 800);
    store64(f + FIGURE_ERA_END, 0 - 700);
    hadara_set_figures(greek, gr_figs, 2);

    # --- Norse practices — Price (2019) ---
    var no_practices = alloc(PRACTICE_SIZE * 3);
    p = no_practices;
    store64(p + PRACTICE_NAME_PTR, "Blot");
    store64(p + PRACTICE_NAME_LEN, 4);
    store64(p + PRACTICE_CATEGORY, PRACTICE_RITUAL);
    store64(p + PRACTICE_FREQUENCY, FREQ_SEASONAL);
    store64(p + PRACTICE_SACRED, 1);
    p = no_practices + PRACTICE_SIZE;
    store64(p + PRACTICE_NAME_PTR, "Thing Assembly");
    store64(p + PRACTICE_NAME_LEN, 14);
    store64(p + PRACTICE_CATEGORY, PRACTICE_SOCIAL);
    store64(p + PRACTICE_FREQUENCY, FREQ_ANNUAL);
    store64(p + PRACTICE_SACRED, 0);
    p = no_practices + PRACTICE_SIZE * 2;
    store64(p + PRACTICE_NAME_PTR, "Ship Burial");
    store64(p + PRACTICE_NAME_LEN, 11);
    store64(p + PRACTICE_CATEGORY, PRACTICE_RITUAL);
    store64(p + PRACTICE_FREQUENCY, FREQ_LIFECYCLE);
    store64(p + PRACTICE_SACRED, 1);
    hadara_set_practices(norse, no_practices, 3);

    # --- Norse art forms ---
    var no_arts = alloc(ART_FORM_SIZE * 3);
    a = no_arts;
    store64(a + ART_FORM_NAME_PTR, "Skaldic Poetry");
    store64(a + ART_FORM_NAME_LEN, 14);
    store64(a + ART_FORM_MEDIUM, ART_ORAL_TRADITION);
    a = no_arts + ART_FORM_SIZE;
    store64(a + ART_FORM_NAME_PTR, "Runecraft");
    store64(a + ART_FORM_NAME_LEN, 9);
    store64(a + ART_FORM_MEDIUM, ART_CALLIGRAPHY);
    a = no_arts + ART_FORM_SIZE * 2;
    store64(a + ART_FORM_NAME_PTR, "Wood Carving");
    store64(a + ART_FORM_NAME_LEN, 12);
    store64(a + ART_FORM_MEDIUM, ART_VISUAL);
    hadara_set_art_forms(norse, no_arts, 3);

    # --- Chinese practices — Stearns (2001) ---
    var ch_practices = alloc(PRACTICE_SIZE * 3);
    p = ch_practices;
    store64(p + PRACTICE_NAME_PTR, "Ancestor Veneration");
    store64(p + PRACTICE_NAME_LEN, 19);
    store64(p + PRACTICE_CATEGORY, PRACTICE_RITUAL);
    store64(p + PRACTICE_FREQUENCY, FREQ_DAILY);
    store64(p + PRACTICE_SACRED, 1);
    p = ch_practices + PRACTICE_SIZE;
    store64(p + PRACTICE_NAME_PTR, "Lunar New Year");
    store64(p + PRACTICE_NAME_LEN, 14);
    store64(p + PRACTICE_CATEGORY, PRACTICE_FESTIVAL);
    store64(p + PRACTICE_FREQUENCY, FREQ_ANNUAL);
    store64(p + PRACTICE_SACRED, 1);
    p = ch_practices + PRACTICE_SIZE * 2;
    store64(p + PRACTICE_NAME_PTR, "Tai Chi");
    store64(p + PRACTICE_NAME_LEN, 7);
    store64(p + PRACTICE_CATEGORY, PRACTICE_MARTIAL);
    store64(p + PRACTICE_FREQUENCY, FREQ_DAILY);
    store64(p + PRACTICE_SACRED, 0);
    hadara_set_practices(chinese, ch_practices, 3);

    # --- Chinese art forms ---
    var ch_arts = alloc(ART_FORM_SIZE * 3);
    a = ch_arts;
    store64(a + ART_FORM_NAME_PTR, "Chinese Calligraphy");
    store64(a + ART_FORM_NAME_LEN, 19);
    store64(a + ART_FORM_MEDIUM, ART_CALLIGRAPHY);
    a = ch_arts + ART_FORM_SIZE;
    store64(a + ART_FORM_NAME_PTR, "Beijing Opera");
    store64(a + ART_FORM_NAME_LEN, 13);
    store64(a + ART_FORM_MEDIUM, ART_THEATER);
    a = ch_arts + ART_FORM_SIZE * 2;
    store64(a + ART_FORM_NAME_PTR, "Silk Weaving");
    store64(a + ART_FORM_NAME_LEN, 12);
    store64(a + ART_FORM_MEDIUM, ART_TEXTILE);
    hadara_set_art_forms(chinese, ch_arts, 3);

    # --- Chinese figures ---
    var ch_figs = alloc(FIGURE_SIZE * 2);
    f = ch_figs;
    store64(f + FIGURE_NAME_PTR, "Confucius");
    store64(f + FIGURE_NAME_LEN, 9);
    store64(f + FIGURE_ROLE_PTR, "Founded Confucianism, shaped East Asian ethics and governance");
    store64(f + FIGURE_ROLE_LEN, 60);
    store64(f + FIGURE_ERA_START, 0 - 551);
    store64(f + FIGURE_ERA_END, 0 - 479);
    f = ch_figs + FIGURE_SIZE;
    store64(f + FIGURE_NAME_PTR, "Laozi");
    store64(f + FIGURE_NAME_LEN, 5);
    store64(f + FIGURE_ROLE_PTR, "Traditional author of Tao Te Ching, founded Daoism");
    store64(f + FIGURE_ROLE_LEN, 51);
    store64(f + FIGURE_ERA_START, 0 - 600);
    store64(f + FIGURE_ERA_END, 0 - 500);
    hadara_set_figures(chinese, ch_figs, 2);

    # --- Chinese texts ---
    var ch_texts = alloc(TEXT_SIZE * 2);
    t = ch_texts;
    store64(t + TEXT_TITLE_PTR, "Tao Te Ching");
    store64(t + TEXT_TITLE_LEN, 12);
    store64(t + TEXT_AUTHOR_PTR, "Laozi");
    store64(t + TEXT_AUTHOR_LEN, 5);
    store64(t + TEXT_YEAR, 0 - 400);
    store64(t + TEXT_SACRED, 1);
    t = ch_texts + TEXT_SIZE;
    store64(t + TEXT_TITLE_PTR, "Analerta");
    store64(t + TEXT_TITLE_LEN, 8);
    store64(t + TEXT_AUTHOR_PTR, "Confucius");
    store64(t + TEXT_AUTHOR_LEN, 9);
    store64(t + TEXT_YEAR, 0 - 475);
    store64(t + TEXT_SACRED, 0);
    hadara_set_texts(chinese, ch_texts, 2);

    # --- Maya practices — Coe (2015) ---
    var ma_practices = alloc(PRACTICE_SIZE * 2);
    p = ma_practices;
    store64(p + PRACTICE_NAME_PTR, "Ballgame");
    store64(p + PRACTICE_NAME_LEN, 8);
    store64(p + PRACTICE_CATEGORY, PRACTICE_RITUAL);
    store64(p + PRACTICE_FREQUENCY, FREQ_SEASONAL);
    store64(p + PRACTICE_SACRED, 1);
    p = ma_practices + PRACTICE_SIZE;
    store64(p + PRACTICE_NAME_PTR, "Bloodletting Rite");
    store64(p + PRACTICE_NAME_LEN, 17);
    store64(p + PRACTICE_CATEGORY, PRACTICE_RITUAL);
    store64(p + PRACTICE_FREQUENCY, FREQ_SEASONAL);
    store64(p + PRACTICE_SACRED, 1);
    hadara_set_practices(maya, ma_practices, 2);

    # --- Maya art forms ---
    var ma_arts = alloc(ART_FORM_SIZE * 3);
    a = ma_arts;
    store64(a + ART_FORM_NAME_PTR, "Glyph Writing");
    store64(a + ART_FORM_NAME_LEN, 13);
    store64(a + ART_FORM_MEDIUM, ART_CALLIGRAPHY);
    a = ma_arts + ART_FORM_SIZE;
    store64(a + ART_FORM_NAME_PTR, "Stela Sculpture");
    store64(a + ART_FORM_NAME_LEN, 15);
    store64(a + ART_FORM_MEDIUM, ART_VISUAL);
    a = ma_arts + ART_FORM_SIZE * 2;
    store64(a + ART_FORM_NAME_PTR, "Pyramid Architecture");
    store64(a + ART_FORM_NAME_LEN, 20);
    store64(a + ART_FORM_MEDIUM, ART_ARCHITECTURE);
    hadara_set_art_forms(maya, ma_arts, 3);

    # --- Aboriginal Australian practices — Flood (2006) ---
    var ab_practices = alloc(PRACTICE_SIZE * 3);
    p = ab_practices;
    store64(p + PRACTICE_NAME_PTR, "Corroboree");
    store64(p + PRACTICE_NAME_LEN, 10);
    store64(p + PRACTICE_CATEGORY, PRACTICE_CEREMONY);
    store64(p + PRACTICE_FREQUENCY, FREQ_SEASONAL);
    store64(p + PRACTICE_SACRED, 1);
    p = ab_practices + PRACTICE_SIZE;
    store64(p + PRACTICE_NAME_PTR, "Walkabout");
    store64(p + PRACTICE_NAME_LEN, 9);
    store64(p + PRACTICE_CATEGORY, PRACTICE_RITUAL);
    store64(p + PRACTICE_FREQUENCY, FREQ_LIFECYCLE);
    store64(p + PRACTICE_SACRED, 1);
    p = ab_practices + PRACTICE_SIZE * 2;
    store64(p + PRACTICE_NAME_PTR, "Smoking Ceremony");
    store64(p + PRACTICE_NAME_LEN, 16);
    store64(p + PRACTICE_CATEGORY, PRACTICE_RITUAL);
    store64(p + PRACTICE_FREQUENCY, FREQ_LIFECYCLE);
    store64(p + PRACTICE_SACRED, 1);
    hadara_set_practices(aboriginal, ab_practices, 3);

    # --- Aboriginal art forms ---
    var ab_arts = alloc(ART_FORM_SIZE * 3);
    a = ab_arts;
    store64(a + ART_FORM_NAME_PTR, "Dot Painting");
    store64(a + ART_FORM_NAME_LEN, 12);
    store64(a + ART_FORM_MEDIUM, ART_VISUAL);
    a = ab_arts + ART_FORM_SIZE;
    store64(a + ART_FORM_NAME_PTR, "Didgeridoo");
    store64(a + ART_FORM_NAME_LEN, 10);
    store64(a + ART_FORM_MEDIUM, ART_MUSIC);
    a = ab_arts + ART_FORM_SIZE * 2;
    store64(a + ART_FORM_NAME_PTR, "Dreamtime Stories");
    store64(a + ART_FORM_NAME_LEN, 17);
    store64(a + ART_FORM_MEDIUM, ART_ORAL_TRADITION);
    hadara_set_art_forms(aboriginal, ab_arts, 3);

    # --- Scottish practices — Cunliffe (2018) ---
    var sc_practices = alloc(PRACTICE_SIZE * 2);
    p = sc_practices;
    store64(p + PRACTICE_NAME_PTR, "Ceilidh");
    store64(p + PRACTICE_NAME_LEN, 7);
    store64(p + PRACTICE_CATEGORY, PRACTICE_FESTIVAL);
    store64(p + PRACTICE_FREQUENCY, FREQ_WEEKLY);
    store64(p + PRACTICE_SACRED, 0);
    p = sc_practices + PRACTICE_SIZE;
    store64(p + PRACTICE_NAME_PTR, "Highland Games");
    store64(p + PRACTICE_NAME_LEN, 14);
    store64(p + PRACTICE_CATEGORY, PRACTICE_FESTIVAL);
    store64(p + PRACTICE_FREQUENCY, FREQ_ANNUAL);
    store64(p + PRACTICE_SACRED, 0);
    hadara_set_practices(scottish, sc_practices, 2);

    # --- Scottish art forms ---
    var sc_arts = alloc(ART_FORM_SIZE * 2);
    a = sc_arts;
    store64(a + ART_FORM_NAME_PTR, "Pibroch");
    store64(a + ART_FORM_NAME_LEN, 7);
    store64(a + ART_FORM_MEDIUM, ART_MUSIC);
    a = sc_arts + ART_FORM_SIZE;
    store64(a + ART_FORM_NAME_PTR, "Gaelic Song");
    store64(a + ART_FORM_NAME_LEN, 11);
    store64(a + ART_FORM_MEDIUM, ART_ORAL_TRADITION);
    hadara_set_art_forms(scottish, sc_arts, 2);

    # --- Roman practices — Boatwright (2012) ---
    var ro_practices = alloc(PRACTICE_SIZE * 3);
    p = ro_practices;
    store64(p + PRACTICE_NAME_PTR, "Gladiatorial Games");
    store64(p + PRACTICE_NAME_LEN, 18);
    store64(p + PRACTICE_CATEGORY, PRACTICE_FESTIVAL);
    store64(p + PRACTICE_FREQUENCY, FREQ_SEASONAL);
    store64(p + PRACTICE_SACRED, 0);
    p = ro_practices + PRACTICE_SIZE;
    store64(p + PRACTICE_NAME_PTR, "Triumph");
    store64(p + PRACTICE_NAME_LEN, 7);
    store64(p + PRACTICE_CATEGORY, PRACTICE_CEREMONY);
    store64(p + PRACTICE_FREQUENCY, FREQ_SPONTANEOUS);
    store64(p + PRACTICE_SACRED, 1);
    p = ro_practices + PRACTICE_SIZE * 2;
    store64(p + PRACTICE_NAME_PTR, "Saturnalia");
    store64(p + PRACTICE_NAME_LEN, 10);
    store64(p + PRACTICE_CATEGORY, PRACTICE_FESTIVAL);
    store64(p + PRACTICE_FREQUENCY, FREQ_ANNUAL);
    store64(p + PRACTICE_SACRED, 1);
    hadara_set_practices(roman, ro_practices, 3);

    # --- Roman art forms ---
    var ro_arts = alloc(ART_FORM_SIZE * 3);
    a = ro_arts;
    store64(a + ART_FORM_NAME_PTR, "Mosaic");
    store64(a + ART_FORM_NAME_LEN, 6);
    store64(a + ART_FORM_MEDIUM, ART_VISUAL);
    a = ro_arts + ART_FORM_SIZE;
    store64(a + ART_FORM_NAME_PTR, "Aqueduct Engineering");
    store64(a + ART_FORM_NAME_LEN, 20);
    store64(a + ART_FORM_MEDIUM, ART_ARCHITECTURE);
    a = ro_arts + ART_FORM_SIZE * 2;
    store64(a + ART_FORM_NAME_PTR, "Latin Oratory");
    store64(a + ART_FORM_NAME_LEN, 13);
    store64(a + ART_FORM_MEDIUM, ART_ORAL_TRADITION);
    hadara_set_art_forms(roman, ro_arts, 3);

    # --- Roman figures ---
    var ro_figs = alloc(FIGURE_SIZE * 2);
    f = ro_figs;
    store64(f + FIGURE_NAME_PTR, "Julius Caesar");
    store64(f + FIGURE_NAME_LEN, 13);
    store64(f + FIGURE_ROLE_PTR, "General and statesman who transformed Republic into Empire");
    store64(f + FIGURE_ROLE_LEN, 58);
    store64(f + FIGURE_ERA_START, 0 - 100);
    store64(f + FIGURE_ERA_END, 0 - 44);
    f = ro_figs + FIGURE_SIZE;
    store64(f + FIGURE_NAME_PTR, "Virgil");
    store64(f + FIGURE_NAME_LEN, 6);
    store64(f + FIGURE_ROLE_PTR, "Poet of the Aeneid, foundational Latin literary tradition");
    store64(f + FIGURE_ROLE_LEN, 57);
    store64(f + FIGURE_ERA_START, 0 - 70);
    store64(f + FIGURE_ERA_END, 0 - 19);
    hadara_set_figures(roman, ro_figs, 2);

    # --- Additional relations ---

    # Greek influenced Roman — Boardman (1970--2005)
    var rels2 = alloc(RELATION_SIZE * 2);
    r = rels2;
    store64(r + RELATION_SOURCE, greek);
    store64(r + RELATION_TARGET, roman);
    store64(r + RELATION_TYPE, REL_INFLUENCED);
    store64(r + RELATION_PERIOD_START, 0 - 300);
    store64(r + RELATION_PERIOD_END, 0 - 100);

    # Chinese influenced Japanese — Varley (2000)
    r = rels2 + RELATION_SIZE;
    store64(r + RELATION_SOURCE, chinese);
    store64(r + RELATION_TARGET, japanese);
    store64(r + RELATION_TYPE, REL_INFLUENCED);
    store64(r + RELATION_PERIOD_START, 500);
    store64(r + RELATION_PERIOD_END, 900);

    hadara_set_relations(greek, rels2, 1);
    hadara_set_relations(roman, rels2, 1);
    hadara_set_relations(chinese, rels2 + RELATION_SIZE, 1);
    hadara_set_relations(japanese, rels2 + RELATION_SIZE, 1);

    # --- West African figure — Levtzion & Pouwels (2000), Niane (1965) ---
    var wa_figs = alloc(FIGURE_SIZE * 2);
    f = wa_figs;
    store64(f + FIGURE_NAME_PTR, "Sundiata Keita");
    store64(f + FIGURE_NAME_LEN, 14);
    store64(f + FIGURE_ROLE_PTR, "Founded Mali Empire, codified Manden Charter");
    store64(f + FIGURE_ROLE_LEN, 45);
    store64(f + FIGURE_ERA_START, 1217);
    store64(f + FIGURE_ERA_END, 1255);
    f = wa_figs + FIGURE_SIZE;
    store64(f + FIGURE_NAME_PTR, "Mansa Musa");
    store64(f + FIGURE_NAME_LEN, 10);
    store64(f + FIGURE_ROLE_PTR, "Richest person in history, patronized Timbuktu scholarship");
    store64(f + FIGURE_ROLE_LEN, 58);
    store64(f + FIGURE_ERA_START, 1280);
    store64(f + FIGURE_ERA_END, 1337);
    hadara_set_figures(westafrican, wa_figs, 2);

    return hadara_count;
}
