    # --- Swahili — Nurse & Spear (1985) ---
    var sw_practices = alloc(PRACTICE_SIZE * 2);
    p = sw_practices;
    store64(p + PRACTICE_NAME_PTR, "Dhow Trading");
    store64(p + PRACTICE_NAME_LEN, 12);
    store64(p + PRACTICE_CATEGORY, PRACTICE_SOCIAL);
    store64(p + PRACTICE_FREQUENCY, FREQ_DAILY);
    store64(p + PRACTICE_SACRED, 0);
    p = sw_practices + PRACTICE_SIZE;
    store64(p + PRACTICE_NAME_PTR, "Maulidi Festival");
    store64(p + PRACTICE_NAME_LEN, 16);
    store64(p + PRACTICE_CATEGORY, PRACTICE_FESTIVAL);
    store64(p + PRACTICE_FREQUENCY, FREQ_ANNUAL);
    store64(p + PRACTICE_SACRED, 1);
    hadara_set_practices(CID_SWAHILI, sw_practices, 2);

    var sw_arts = alloc(ART_FORM_SIZE * 2);
    a = sw_arts;
    store64(a + ART_FORM_NAME_PTR, "Taarab Music");
    store64(a + ART_FORM_NAME_LEN, 12);
    store64(a + ART_FORM_MEDIUM, ART_MUSIC);
    a = sw_arts + ART_FORM_SIZE;
    store64(a + ART_FORM_NAME_PTR, "Coral Stone Architecture");
    store64(a + ART_FORM_NAME_LEN, 24);
    store64(a + ART_FORM_MEDIUM, ART_ARCHITECTURE);
    hadara_set_art_forms(CID_SWAHILI, sw_arts, 2);

    # --- Amazigh — Brett & Fentress (1996) ---
    var am_practices = alloc(PRACTICE_SIZE * 2);
    p = am_practices;
    store64(p + PRACTICE_NAME_PTR, "Ahwash Dance");
    store64(p + PRACTICE_NAME_LEN, 12);
    store64(p + PRACTICE_CATEGORY, PRACTICE_ART);
    store64(p + PRACTICE_FREQUENCY, FREQ_SEASONAL);
    store64(p + PRACTICE_SACRED, 0);
    p = am_practices + PRACTICE_SIZE;
    store64(p + PRACTICE_NAME_PTR, "Yennayer New Year");
    store64(p + PRACTICE_NAME_LEN, 17);
    store64(p + PRACTICE_CATEGORY, PRACTICE_FESTIVAL);
    store64(p + PRACTICE_FREQUENCY, FREQ_ANNUAL);
    store64(p + PRACTICE_SACRED, 0);
    hadara_set_practices(CID_AMAZIGH, am_practices, 2);

    var am_arts = alloc(ART_FORM_SIZE * 2);
    a = am_arts;
    store64(a + ART_FORM_NAME_PTR, "Tifinagh Script");
    store64(a + ART_FORM_NAME_LEN, 15);
    store64(a + ART_FORM_MEDIUM, ART_CALLIGRAPHY);
    a = am_arts + ART_FORM_SIZE;
    store64(a + ART_FORM_NAME_PTR, "Berber Carpet Weaving");
    store64(a + ART_FORM_NAME_LEN, 21);
    store64(a + ART_FORM_MEDIUM, ART_TEXTILE);
    hadara_set_art_forms(CID_AMAZIGH, am_arts, 2);

    # --- Inuit — Stern (2004) ---
    var in_practices = alloc(PRACTICE_SIZE * 2);
    p = in_practices;
    store64(p + PRACTICE_NAME_PTR, "Drum Dance");
    store64(p + PRACTICE_NAME_LEN, 10);
    store64(p + PRACTICE_CATEGORY, PRACTICE_CEREMONY);
    store64(p + PRACTICE_FREQUENCY, FREQ_SEASONAL);
    store64(p + PRACTICE_SACRED, 1);
    p = in_practices + PRACTICE_SIZE;
    store64(p + PRACTICE_NAME_PTR, "Throat Singing");
    store64(p + PRACTICE_NAME_LEN, 14);
    store64(p + PRACTICE_CATEGORY, PRACTICE_ART);
    store64(p + PRACTICE_FREQUENCY, FREQ_SPONTANEOUS);
    store64(p + PRACTICE_SACRED, 0);
    hadara_set_practices(CID_INUIT, in_practices, 2);

    var in_arts = alloc(ART_FORM_SIZE * 2);
    a = in_arts;
    store64(a + ART_FORM_NAME_PTR, "Soapstone Carving");
    store64(a + ART_FORM_NAME_LEN, 17);
    store64(a + ART_FORM_MEDIUM, ART_VISUAL);
    a = in_arts + ART_FORM_SIZE;
    store64(a + ART_FORM_NAME_PTR, "Oral Storytelling");
    store64(a + ART_FORM_NAME_LEN, 17);
    store64(a + ART_FORM_MEDIUM, ART_ORAL_TRADITION);
    hadara_set_art_forms(CID_INUIT, in_arts, 2);

    # --- Khmer — Higham (2001) ---
    var km_practices = alloc(PRACTICE_SIZE * 2);
    p = km_practices;
    store64(p + PRACTICE_NAME_PTR, "Water Festival");
    store64(p + PRACTICE_NAME_LEN, 14);
    store64(p + PRACTICE_CATEGORY, PRACTICE_FESTIVAL);
    store64(p + PRACTICE_FREQUENCY, FREQ_ANNUAL);
    store64(p + PRACTICE_SACRED, 1);
    p = km_practices + PRACTICE_SIZE;
    store64(p + PRACTICE_NAME_PTR, "Theravada Meditation");
    store64(p + PRACTICE_NAME_LEN, 20);
    store64(p + PRACTICE_CATEGORY, PRACTICE_RITUAL);
    store64(p + PRACTICE_FREQUENCY, FREQ_DAILY);
    store64(p + PRACTICE_SACRED, 1);
    hadara_set_practices(CID_KHMER, km_practices, 2);

    var km_arts = alloc(ART_FORM_SIZE * 2);
    a = km_arts;
    store64(a + ART_FORM_NAME_PTR, "Apsara Dance");
    store64(a + ART_FORM_NAME_LEN, 12);
    store64(a + ART_FORM_MEDIUM, ART_DANCE);
    a = km_arts + ART_FORM_SIZE;
    store64(a + ART_FORM_NAME_PTR, "Temple Relief Sculpture");
    store64(a + ART_FORM_NAME_LEN, 23);
    store64(a + ART_FORM_MEDIUM, ART_VISUAL);
    hadara_set_art_forms(CID_KHMER, km_arts, 2);

    # --- Ottoman/Turkish — Finkel (2007) ---
    var ot_practices = alloc(PRACTICE_SIZE * 2);
    p = ot_practices;
    store64(p + PRACTICE_NAME_PTR, "Hammam Bathing");
    store64(p + PRACTICE_NAME_LEN, 14);
    store64(p + PRACTICE_CATEGORY, PRACTICE_SOCIAL);
    store64(p + PRACTICE_FREQUENCY, FREQ_WEEKLY);
    store64(p + PRACTICE_SACRED, 0);
    p = ot_practices + PRACTICE_SIZE;
    store64(p + PRACTICE_NAME_PTR, "Whirling Dervish");
    store64(p + PRACTICE_NAME_LEN, 16);
    store64(p + PRACTICE_CATEGORY, PRACTICE_RITUAL);
    store64(p + PRACTICE_FREQUENCY, FREQ_WEEKLY);
    store64(p + PRACTICE_SACRED, 1);
    hadara_set_practices(CID_OTTOMAN, ot_practices, 2);

    var ot_arts = alloc(ART_FORM_SIZE * 2);
    a = ot_arts;
    store64(a + ART_FORM_NAME_PTR, "Iznik Ceramics");
    store64(a + ART_FORM_NAME_LEN, 14);
    store64(a + ART_FORM_MEDIUM, ART_VISUAL);
    a = ot_arts + ART_FORM_SIZE;
    store64(a + ART_FORM_NAME_PTR, "Ottoman Architecture");
    store64(a + ART_FORM_NAME_LEN, 20);
    store64(a + ART_FORM_MEDIUM, ART_ARCHITECTURE);
    hadara_set_art_forms(CID_OTTOMAN, ot_arts, 2);

    # --- Display dimensions (formality, expressiveness, individualism, directness) ---
    # Sources: Kottak (2019), Ember & Ember (2015), culture-specific refs
    hadara_set_display(CID_EGYPTIAN, 9, 6, 2, 4);     # highly formal, collective, hieratic society
    hadara_set_display(CID_PERSIAN, 8, 7, 4, 4);      # formal, poetic, communal
    hadara_set_display(CID_VEDIC, 8, 6, 3, 4);        # formal, collective, indirect
    hadara_set_display(CID_GREEK, 5, 8, 7, 8);        # moderate formality, expressive, individual, direct
    hadara_set_display(CID_JAPANESE, 9, 3, 2, 3);     # high formality, restrained, collective, indirect
    hadara_set_display(CID_WESTAFRICAN, 6, 8, 3, 6);  # moderate formal, expressive, collective
    hadara_set_display(CID_SCOTTISH, 4, 7, 6, 7);     # informal, expressive, fairly direct
    hadara_set_display(CID_NORSE, 4, 8, 7, 8);        # informal, expressive, individual, direct
    hadara_set_display(CID_ABORIGINAL, 7, 6, 2, 4);   # formal elder protocols, collective
    hadara_set_display(CID_HIPHOP, 2, 9, 8, 9);       # informal, highly expressive, individual, direct
    hadara_set_display(CID_MAYA, 8, 5, 3, 4);         # formal, hieratic, collective
    hadara_set_display(CID_CHINESE, 8, 5, 3, 4);      # formal, restrained, collective, indirect
    hadara_set_display(CID_ROMAN, 8, 6, 4, 7);        # formal, civic, fairly direct
    hadara_set_display(CID_ARAB, 8, 7, 4, 5);         # formal, poetic, communal
    hadara_set_display(CID_KOREAN, 8, 5, 3, 4);       # formal, restrained, collective
    hadara_set_display(CID_TIBETAN, 7, 4, 2, 3);      # formal, restrained, collective, gentle
    hadara_set_display(CID_MESOPOTAMIAN, 9, 5, 3, 5); # highly formal, hieratic
    hadara_set_display(CID_MONGOL, 3, 8, 7, 9);       # informal, bold, individual, very direct
    hadara_set_display(CID_JEWISH, 6, 7, 6, 7);       # moderate, argumentative tradition, direct
    hadara_set_display(CID_BYZANTINE, 9, 5, 3, 4);    # highly formal, liturgical, collective
    hadara_set_display(CID_POLYNESIAN, 6, 8, 4, 6);   # moderate formal, expressive, communal

    # --- Diaspora data ---
    # Stored as arrays of string pointers (regions of dispersal)

    # Jewish diaspora — Seltzer (1980): one of history's most significant dispersals
    var je_dias = alloc(4 * 8);
    store64(je_dias, "Europe");
    store64(je_dias + 8, "North Africa");
    store64(je_dias + 16, "Americas");
    store64(je_dias + 24, "Central Asia");
    hadara_set_diaspora(CID_JEWISH, je_dias, 4);

    # Chinese diaspora — Stearns (2001): Southeast Asia, Americas, worldwide
    var ch_dias = alloc(3 * 8);
    store64(ch_dias, "Southeast Asia");
    store64(ch_dias + 8, "Americas");
    store64(ch_dias + 16, "Oceania");
    hadara_set_diaspora(CID_CHINESE, ch_dias, 3);

    # West African diaspora — Iliffe (2007): transatlantic slave trade dispersal
    var wa_dias = alloc(3 * 8);
    store64(wa_dias, "Caribbean");
    store64(wa_dias + 8, "Americas");
    store64(wa_dias + 16, "Europe");
    hadara_set_diaspora(CID_WESTAFRICAN, wa_dias, 3);

    # Polynesian diaspora — Howe (2006): Pacific expansion
    var po_dias = alloc(3 * 8);
    store64(po_dias, "Hawaii");
    store64(po_dias + 8, "Aotearoa");
    store64(po_dias + 16, "Rapa Nui");
    hadara_set_diaspora(CID_POLYNESIAN, po_dias, 3);

    # Hip-Hop diaspora — Chang (2005): global spread from NYC
    var hp_dias = alloc(3 * 8);
    store64(hp_dias, "Europe");
    store64(hp_dias + 8, "East Asia");
    store64(hp_dias + 16, "Africa");
    hadara_set_diaspora(CID_HIPHOP, hp_dias, 3);

    # Persian diaspora — Brosius (2006): post-revolution dispersal
    var pe_dias = alloc(2 * 8);
    store64(pe_dias, "Americas");
    store64(pe_dias + 8, "Europe");
    hadara_set_diaspora(CID_PERSIAN, pe_dias, 2);

    return 0;
}

fn hadara_seed_values() {
    # ================================================================
    # Values/Worldview — Kottak (2019), Ember & Ember (2015)
    # Each culture gets 3-4 core values as string pointers (8 bytes each)
    # ================================================================

    # Egyptian: Ma'at (cosmic order), afterlife, divine kingship
    var eg_vals = alloc(3 * 8);
    store64(eg_vals, "Ma'at");
    store64(eg_vals + 8, "Afterlife preparation");
    store64(eg_vals + 16, "Divine kingship");
    hadara_set_values(CID_EGYPTIAN, eg_vals, 3);

    # Persian: Asha (truth/righteousness), hospitality, dualism
    var pe_vals = alloc(3 * 8);
    store64(pe_vals, "Asha");
    store64(pe_vals + 8, "Hospitality");
    store64(pe_vals + 16, "Cosmic dualism");
    hadara_set_values(CID_PERSIAN, pe_vals, 3);

    # Vedic: Dharma, ahimsa, cyclical time
    var ve_vals = alloc(3 * 8);
    store64(ve_vals, "Dharma");
    store64(ve_vals + 8, "Ahimsa");
    store64(ve_vals + 16, "Cyclical time");
    hadara_set_values(CID_VEDIC, ve_vals, 3);

    # Greek: Arete (excellence), logos, democratic participation
    var gr_vals = alloc(3 * 8);
    store64(gr_vals, "Arete");
    store64(gr_vals + 8, "Logos");
    store64(gr_vals + 16, "Democratic participation");
    hadara_set_values(CID_GREEK, gr_vals, 3);

    # Japanese: Wa (harmony), on (obligation), mono no aware
    var jp_vals = alloc(3 * 8);
    store64(jp_vals, "Wa");
    store64(jp_vals + 8, "On");
    store64(jp_vals + 16, "Mono no aware");
    hadara_set_values(CID_JAPANESE, jp_vals, 3);

    # West African: Ubuntu, communalism, ancestral continuity
    var wa_vals = alloc(3 * 8);
    store64(wa_vals, "Ubuntu");
    store64(wa_vals + 8, "Communalism");
    store64(wa_vals + 16, "Ancestral continuity");
    hadara_set_values(CID_WESTAFRICAN, wa_vals, 3);

    # Norse: Honor, fate (wyrd), heroic death
    var no_vals = alloc(3 * 8);
    store64(no_vals, "Honor");
    store64(no_vals + 8, "Wyrd");
    store64(no_vals + 16, "Heroic death");
    hadara_set_values(CID_NORSE, no_vals, 3);

    # Hip-Hop: Authenticity, self-expression, community uplift
    var hp_vals = alloc(3 * 8);
    store64(hp_vals, "Authenticity");
    store64(hp_vals + 8, "Self-expression");
    store64(hp_vals + 16, "Community uplift");
    hadara_set_values(CID_HIPHOP, hp_vals, 3);

    # Roman: Virtus, pietas, civic duty
    var ro_vals = alloc(3 * 8);
    store64(ro_vals, "Virtus");
    store64(ro_vals + 8, "Pietas");
    store64(ro_vals + 16, "Civic duty");
    hadara_set_values(CID_ROMAN, ro_vals, 3);

    # Chinese: Ren (benevolence), li (ritual propriety), filial piety
    var ch_vals = alloc(3 * 8);
    store64(ch_vals, "Ren");
    store64(ch_vals + 8, "Li");
    store64(ch_vals + 16, "Filial piety");
    hadara_set_values(CID_CHINESE, ch_vals, 3);

    # Aboriginal: Dreamtime, country (land-spirit bond), kinship
    var ab_vals = alloc(3 * 8);
    store64(ab_vals, "Dreamtime");
    store64(ab_vals + 8, "Country");
    store64(ab_vals + 16, "Kinship law");
    hadara_set_values(CID_ABORIGINAL, ab_vals, 3);

    # Maya: K'uhul (sacredness), cyclical calendar, reciprocity with gods
    var ma_vals = alloc(3 * 8);
    store64(ma_vals, "K'uhul");
    store64(ma_vals + 8, "Cyclical calendar");
    store64(ma_vals + 16, "Divine reciprocity");
    hadara_set_values(CID_MAYA, ma_vals, 3);

    # Scottish: Clan loyalty, independence, oral tradition
    var sc_vals = alloc(3 * 8);
    store64(sc_vals, "Clan loyalty");
    store64(sc_vals + 8, "Independence");
    store64(sc_vals + 16, "Oral tradition");
    hadara_set_values(CID_SCOTTISH, sc_vals, 3);

    # Arab: Ummah (community), hospitality, divine submission
    var ar_vals = alloc(3 * 8);
    store64(ar_vals, "Ummah");
    store64(ar_vals + 8, "Hospitality");
    store64(ar_vals + 16, "Tawhid");
    hadara_set_values(CID_ARAB, ar_vals, 3);

    # Jewish: Tikkun olam, covenant, learning/study
    var je_vals = alloc(3 * 8);
    store64(je_vals, "Tikkun olam");
    store64(je_vals + 8, "Covenant");
    store64(je_vals + 16, "Torah study");
    hadara_set_values(CID_JEWISH, je_vals, 3);

    # Korean: Jeong (deep affection), han (collective grief), filial piety
    var ko_vals = alloc(3 * 8);
    store64(ko_vals, "Jeong");
    store64(ko_vals + 8, "Han");
    store64(ko_vals + 16, "Filial piety");
    hadara_set_values(CID_KOREAN, ko_vals, 3);

    # Tibetan: Compassion, impermanence, liberation
    var ti_vals = alloc(3 * 8);
    store64(ti_vals, "Compassion");
    store64(ti_vals + 8, "Impermanence");
    store64(ti_vals + 16, "Liberation");
    hadara_set_values(CID_TIBETAN, ti_vals, 3);

    # Mongol: Eternal Blue Sky, freedom, strength
    var mo_vals = alloc(3 * 8);
    store64(mo_vals, "Eternal Blue Sky");
    store64(mo_vals + 8, "Freedom");
    store64(mo_vals + 16, "Strength");
    hadara_set_values(CID_MONGOL, mo_vals, 3);

    # Byzantine: Orthodoxy, imperial continuity, divine mandate
    var by_vals = alloc(3 * 8);
    store64(by_vals, "Orthodoxy");
    store64(by_vals + 8, "Imperial continuity");
    store64(by_vals + 16, "Theosis");
    hadara_set_values(CID_BYZANTINE, by_vals, 3);

    # Mesopotamian: Divine order, civilization, written law
    var ms_vals = alloc(3 * 8);
    store64(ms_vals, "Divine order");
    store64(ms_vals + 8, "Civilization");
    store64(ms_vals + 16, "Written law");
    hadara_set_values(CID_MESOPOTAMIAN, ms_vals, 3);

    # Polynesian: Mana, tapu, navigation mastery
    var po_vals = alloc(3 * 8);
    store64(po_vals, "Mana");
    store64(po_vals + 8, "Tapu");
    store64(po_vals + 16, "Navigation mastery");
    hadara_set_values(CID_POLYNESIAN, po_vals, 3);

    # Maori: manaakitanga, kaitiakitanga, whakapapa
    var ma2_vals = alloc(3 * 8);
    store64(ma2_vals, "Manaakitanga");
    store64(ma2_vals + 8, "Kaitiakitanga");
    store64(ma2_vals + 16, "Whakapapa");
    hadara_set_values(CID_MAORI, ma2_vals, 3);

    # Sikh: seva, equality, martial valor
    var si_vals = alloc(3 * 8);
    store64(si_vals, "Seva");
    store64(si_vals + 8, "Equality");
    store64(si_vals + 16, "Martial valor");
    hadara_set_values(CID_SIKH, si_vals, 3);

    # Ethiopian: faith, sovereignty, coffee ritual
    var et_vals = alloc(3 * 8);
    store64(et_vals, "Faith");
    store64(et_vals + 8, "Sovereignty");
    store64(et_vals + 16, "Hospitality");
    hadara_set_values(CID_ETHIOPIAN, et_vals, 3);

    # Tamil: sangam, devotion, language pride
    var ta_vals = alloc(3 * 8);
    store64(ta_vals, "Sangam");
    store64(ta_vals + 8, "Bhakti");
    store64(ta_vals + 16, "Language pride");
    hadara_set_values(CID_TAMIL, ta_vals, 3);

    # Javanese: halus (refinement), harmony, mysticism
    var jv_vals = alloc(3 * 8);
    store64(jv_vals, "Halus");
    store64(jv_vals + 8, "Rukun");
    store64(jv_vals + 16, "Kebatinan");
    hadara_set_values(CID_JAVANESE, jv_vals, 3);

    # Armenian: survival, faith, education
    var arm_vals = alloc(3 * 8);
    store64(arm_vals, "Survival");
    store64(arm_vals + 8, "Apostolic faith");
    store64(arm_vals + 16, "Education");
    hadara_set_values(CID_ARMENIAN, arm_vals, 3);

    # Romani: freedom, family, oral tradition
    var rom_vals = alloc(3 * 8);
    store64(rom_vals, "Freedom");
    store64(rom_vals + 8, "Family");
    store64(rom_vals + 16, "Romanipen");
    hadara_set_values(CID_ROMANI, rom_vals, 3);

    # Basque: independence, communal labor, oral tradition
    var bq_vals = alloc(3 * 8);
    store64(bq_vals, "Auzolan");
    store64(bq_vals + 8, "Independence");
    store64(bq_vals + 16, "Bertsolaritza");
    hadara_set_values(CID_BASQUE, bq_vals, 3);

    # Haudenosaunee: Great Law, consensus, seventh generation
    var hd_vals = alloc(3 * 8);
    store64(hd_vals, "Great Law");
    store64(hd_vals + 8, "Consensus");
    store64(hd_vals + 16, "Seventh generation");
    hadara_set_values(CID_HAUDENOSAUNEE, hd_vals, 3);

    # East Coast Hip-Hop: lyricism, battle, street knowledge
    var ec_vals = alloc(3 * 8);
    store64(ec_vals, "Lyricism");
    store64(ec_vals + 8, "Battle");
    store64(ec_vals + 16, "Street knowledge");
    hadara_set_values(CID_EASTCOAST, ec_vals, 3);

    # Somali: xeer (customary law), clan honor, poetry
    var so2_vals = alloc(3 * 8);
    store64(so2_vals, "Xeer");
    store64(so2_vals + 8, "Clan honor");
    store64(so2_vals + 16, "Poetry");
    hadara_set_values(CID_SOMALI, so2_vals, 3);

    # Tuareg: freedom, hospitality, desert mastery
    var tu_vals = alloc(3 * 8);
    store64(tu_vals, "Aman");
    store64(tu_vals + 8, "Hospitality");
    store64(tu_vals + 16, "Desert mastery");
    hadara_set_values(CID_TUAREG, tu_vals, 3);

    # Zulu: ubuntu, warrior courage, respect for elders
    var zu_vals = alloc(3 * 8);
    store64(zu_vals, "Ubuntu");
    store64(zu_vals + 8, "Isibindi");
    store64(zu_vals + 16, "Hlonipha");
    hadara_set_values(CID_ZULU, zu_vals, 3);

    # Georgian: hospitality, wine culture, faith
    var ge_vals = alloc(3 * 8);
    store64(ge_vals, "Stumar-maspin");
    store64(ge_vals + 8, "Wine culture");
    store64(ge_vals + 16, "Orthodox faith");
    hadara_set_values(CID_GEORGIAN, ge_vals, 3);

    # Balinese: tri hita karana (three harmonies), ceremony, artistic devotion
    var ba_vals = alloc(3 * 8);
    store64(ba_vals, "Tri Hita Karana");
    store64(ba_vals + 8, "Ceremony");
    store64(ba_vals + 16, "Artistic devotion");
    hadara_set_values(CID_BALINESE, ba_vals, 3);

    # Igbo: personal achievement, community, oratory
    var ig_vals = alloc(3 * 8);
    store64(ig_vals, "Ogu na Ofo");
    store64(ig_vals + 8, "Personal achievement");
    store64(ig_vals + 16, "Community");
    hadara_set_values(CID_IGBO, ig_vals, 3);

    # Lakota: mitakuye oyasin, sacred hoop, generosity
    var la_vals = alloc(3 * 8);
    store64(la_vals, "Mitakuye Oyasin");
    store64(la_vals + 8, "Sacred Hoop");
    store64(la_vals + 16, "Generosity");
    hadara_set_values(CID_LAKOTA, la_vals, 3);

    # Ainu: kamuy (spirit reverence), reciprocity, nature
    var ai_vals = alloc(3 * 8);
    store64(ai_vals, "Kamuy");
    store64(ai_vals + 8, "Reciprocity");
    store64(ai_vals + 16, "Nature");
    hadara_set_values(CID_AINU, ai_vals, 3);

    # West Coast Hip-Hop: G-funk, laid-back, storytelling
    var wc_vals = alloc(3 * 8);
    store64(wc_vals, "G-funk");
    store64(wc_vals + 8, "Storytelling");
    store64(wc_vals + 16, "West side pride");
    hadara_set_values(CID_WESTCOAST, wc_vals, 3);

    # Southern Hip-Hop: bounce, trunk music, hospitality
    var sth_vals = alloc(3 * 8);
    store64(sth_vals, "Bounce");
    store64(sth_vals + 8, "Trunk music");
    store64(sth_vals + 16, "Southern hospitality");
    hadara_set_values(CID_SOUTHERN, sth_vals, 3);

    # Catalan: seny (common sense), independence, Mediterranean
    var ca_vals = alloc(3 * 8);
    store64(ca_vals, "Seny");
    store64(ca_vals + 8, "Rauxa");
    store64(ca_vals + 16, "Independence");
    hadara_set_values(CID_CATALAN, ca_vals, 3);

    # Aztec: cosmic debt, warrior honor, cyclical destruction/renewal
    var az_vals = alloc(3 * 8);
    store64(az_vals, "Cosmic debt");
    store64(az_vals + 8, "Warrior honor");
    store64(az_vals + 16, "Cyclical renewal");
    hadara_set_values(CID_AZTEC, az_vals, 3);

    # Inca: reciprocity, sun worship, collective labor
    var ic_vals = alloc(3 * 8);
    store64(ic_vals, "Ayni");
    store64(ic_vals + 8, "Inti worship");
    store64(ic_vals + 16, "Collective labor");
    hadara_set_values(CID_INCA, ic_vals, 3);

    # Ottoman: state order, hospitality, cosmopolitanism
    var ot_vals = alloc(3 * 8);
    store64(ot_vals, "Nizam");
    store64(ot_vals + 8, "Hospitality");
    store64(ot_vals + 16, "Cosmopolitanism");
    hadara_set_values(CID_OTTOMAN, ot_vals, 3);

    # Khmer: merit-making, divine kingship, harmony
    var km_vals = alloc(3 * 8);
    store64(km_vals, "Merit-making");
    store64(km_vals + 8, "Devaraja");
    store64(km_vals + 16, "Harmony");
    hadara_set_values(CID_KHMER, km_vals, 3);

    # Swahili: trade, ustaarabu (civilized refinement), synthesis
    var sw_vals = alloc(3 * 8);
    store64(sw_vals, "Trade");
    store64(sw_vals + 8, "Ustaarabu");
    store64(sw_vals + 16, "Cultural synthesis");
    hadara_set_values(CID_SWAHILI, sw_vals, 3);

    # Yoruba: Ase (life force), ancestral duty, community balance
    var yo_vals = alloc(3 * 8);
    store64(yo_vals, "Ase");
    store64(yo_vals + 8, "Ancestral duty");
    store64(yo_vals + 16, "Iwa pele");
    hadara_set_values(CID_YORUBA, yo_vals, 3);

    # Amazigh: freedom, land, oral memory
    var amz_vals = alloc(3 * 8);
    store64(amz_vals, "Tilelli");
    store64(amz_vals + 8, "Tamazirt");
    store64(amz_vals + 16, "Oral memory");
    hadara_set_values(CID_AMAZIGH, amz_vals, 3);

    # Inuit: sharing, respect for animals, resilience
    var in_vals = alloc(3 * 8);
    store64(in_vals, "Sharing");
    store64(in_vals + 8, "Animal respect");
    store64(in_vals + 16, "Resilience");
    hadara_set_values(CID_INUIT, in_vals, 3);

    return 0;
}

fn hadara_seed_relations() {
    var r = 0;
    # ================================================================
    # Phase 4c: Additional relations
    # ================================================================

    var rels4 = alloc(RELATION_SIZE * 6);

    # Arab↔Persian exchange — Hourani (1991): post-conquest cultural synthesis
    r = rels4;
    store64(r + RELATION_SOURCE, CID_ARAB);
    store64(r + RELATION_TARGET, CID_PERSIAN);
    store64(r + RELATION_TYPE, REL_EXCHANGED);
    store64(r + RELATION_PERIOD_START, 651);
    store64(r + RELATION_PERIOD_END, 1258);

    # Vedic→Tibetan influence — Samuel (1993): Buddhist transmission
    r = rels4 + RELATION_SIZE;
    store64(r + RELATION_SOURCE, CID_VEDIC);
    store64(r + RELATION_TARGET, CID_TIBETAN);
    store64(r + RELATION_TYPE, REL_INFLUENCED);
    store64(r + RELATION_PERIOD_START, 700);
    store64(r + RELATION_PERIOD_END, 1200);

    # Mesopotamian→Egyptian exchange — Bronze Age trade networks
    r = rels4 + RELATION_SIZE * 2;
    store64(r + RELATION_SOURCE, CID_MESOPOTAMIAN);
    store64(r + RELATION_TARGET, CID_EGYPTIAN);
    store64(r + RELATION_TYPE, REL_EXCHANGED);
    store64(r + RELATION_PERIOD_START, 0 - 3000);
    store64(r + RELATION_PERIOD_END, 0 - 1200);

    # Byzantine branched from Roman — Mango (1980)
    r = rels4 + RELATION_SIZE * 3;
    store64(r + RELATION_SOURCE, CID_ROMAN);
    store64(r + RELATION_TARGET, CID_BYZANTINE);
    store64(r + RELATION_TYPE, REL_BRANCHED_FROM);
    store64(r + RELATION_PERIOD_START, 330);
    store64(r + RELATION_PERIOD_END, 476);

    # Chinese→Korean influence — Eckert et al. (1990): Confucianism, writing
    r = rels4 + RELATION_SIZE * 4;
    store64(r + RELATION_SOURCE, CID_CHINESE);
    store64(r + RELATION_TARGET, CID_KOREAN);
    store64(r + RELATION_TYPE, REL_INFLUENCED);
    store64(r + RELATION_PERIOD_START, 0 - 100);
    store64(r + RELATION_PERIOD_END, 900);

    # Jewish↔Arab syncretism — Judeo-Arabic philosophical tradition
    r = rels4 + RELATION_SIZE * 5;
    store64(r + RELATION_SOURCE, CID_JEWISH);
    store64(r + RELATION_TARGET, CID_ARAB);
    store64(r + RELATION_TYPE, REL_SYNCRETIZED);
    store64(r + RELATION_PERIOD_START, 800);
    store64(r + RELATION_PERIOD_END, 1200);

    hadara_set_relations(CID_ARAB, rels4, 1);
    hadara_set_relations(CID_TIBETAN, rels4 + RELATION_SIZE, 1);
    hadara_set_relations(CID_MESOPOTAMIAN, rels4 + RELATION_SIZE * 2, 1);
    hadara_set_relations(CID_BYZANTINE, rels4 + RELATION_SIZE * 3, 1);
    hadara_set_relations(CID_KOREAN, rels4 + RELATION_SIZE * 4, 1);

    # Jewish: syncretism with Arab
    hadara_set_relations(CID_JEWISH, rels4 + RELATION_SIZE * 5, 1);

    # Update Persian: original exchange + Arab exchange (built fresh)
    var pe_rels2 = alloc(RELATION_SIZE * 2);
    r = pe_rels2;
    store64(r + RELATION_SOURCE, CID_PERSIAN);
    store64(r + RELATION_TARGET, CID_EGYPTIAN);
    store64(r + RELATION_TYPE, REL_EXCHANGED);
    store64(r + RELATION_PERIOD_START, 0 - 525);
    store64(r + RELATION_PERIOD_END, 0 - 404);
    r = pe_rels2 + RELATION_SIZE;
    store64(r + RELATION_SOURCE, CID_ARAB);
    store64(r + RELATION_TARGET, CID_PERSIAN);
    store64(r + RELATION_TYPE, REL_EXCHANGED);
    store64(r + RELATION_PERIOD_START, 651);
    store64(r + RELATION_PERIOD_END, 1258);
    hadara_set_relations(CID_PERSIAN, pe_rels2, 2);

    # Update Vedic: exchange with Chinese + influence on Tibetan (built fresh)
    var ve_rels2 = alloc(RELATION_SIZE * 2);
    r = ve_rels2;
    store64(r + RELATION_SOURCE, CID_VEDIC);
    store64(r + RELATION_TARGET, CID_CHINESE);
    store64(r + RELATION_TYPE, REL_EXCHANGED);
    store64(r + RELATION_PERIOD_START, 0 - 100);
    store64(r + RELATION_PERIOD_END, 800);
    r = ve_rels2 + RELATION_SIZE;
    store64(r + RELATION_SOURCE, CID_VEDIC);
    store64(r + RELATION_TARGET, CID_TIBETAN);
    store64(r + RELATION_TYPE, REL_INFLUENCED);
    store64(r + RELATION_PERIOD_START, 700);
    store64(r + RELATION_PERIOD_END, 1200);
    hadara_set_relations(CID_VEDIC, ve_rels2, 2);

    return 0;
}

fn hadara_seed_evolution() {
    # ================================================================
    # Evolution tracking — historical status transitions
    # ================================================================

    hadara_evo_init();

    # Scottish Gaelic: Active → Dormant (Highland Clearances, 1750s) → Revived (20th c.)
    hadara_evo_record(CID_SCOTTISH, 843, 0 - 1, CULTURE_ACTIVE);    # emergence
    hadara_evo_record(CID_SCOTTISH, 1746, CULTURE_ACTIVE, CULTURE_DORMANT);  # Culloden
    hadara_evo_record(CID_SCOTTISH, 1970, CULTURE_DORMANT, CULTURE_REVIVED); # Gaelic revival

    # Norse: Active → Historical (end of Viking Age)
    hadara_evo_record(CID_NORSE, 793, 0 - 1, CULTURE_ACTIVE);       # Viking Age begins
    hadara_evo_record(CID_NORSE, 1066, CULTURE_ACTIVE, CULTURE_HISTORICAL); # Battle of Stamford Bridge

    # Egyptian: Active → Historical (Arab conquest)
    hadara_evo_record(CID_EGYPTIAN, 0 - 3100, 0 - 1, CULTURE_ACTIVE);
    hadara_evo_record(CID_EGYPTIAN, 641, CULTURE_ACTIVE, CULTURE_HISTORICAL);

    # Greek: Active → Historical (Roman conquest)
    hadara_evo_record(CID_GREEK, 0 - 800, 0 - 1, CULTURE_ACTIVE);
    hadara_evo_record(CID_GREEK, 0 - 146, CULTURE_ACTIVE, CULTURE_HISTORICAL);

    # Byzantine: Active → Historical (Ottoman conquest)
    hadara_evo_record(CID_BYZANTINE, 330, 0 - 1, CULTURE_ACTIVE);
    hadara_evo_record(CID_BYZANTINE, 1453, CULTURE_ACTIVE, CULTURE_HISTORICAL);

    # Ainu: Active → Dormant (Meiji assimilation) → Revived (modern recognition)
    hadara_evo_record(CID_AINU, 0 - 1000, 0 - 1, CULTURE_ACTIVE);
    hadara_evo_record(CID_AINU, 1869, CULTURE_ACTIVE, CULTURE_DORMANT);  # Hokkaido colonization
    hadara_evo_record(CID_AINU, 2008, CULTURE_DORMANT, CULTURE_REVIVED); # official recognition

    # Aztec: Active → Historical (Spanish conquest)
    hadara_evo_record(CID_AZTEC, 1325, 0 - 1, CULTURE_ACTIVE);
    hadara_evo_record(CID_AZTEC, 1521, CULTURE_ACTIVE, CULTURE_HISTORICAL);

    # ================================================================
    # Relation descriptions — seed desc_ptr/desc_len on existing relations
    # ================================================================

    return 0;
}

fn hadara_seed() {
    hadara_seed_cultures();
    hadara_seed_subentities();
    hadara_seed_subentities_1b();
    hadara_seed_subentities_2();
    hadara_seed_values();
    hadara_seed_relations();
    hadara_seed_evolution();
    return hadara_count;
}

# Relation description lookup — returns a description string for known relation pairs.
# This avoids modifying the already-allocated relation records.
fn hadara_relation_desc(source_id, target_id, rel_type) {
    # Persian↔Egyptian exchange
    if (source_id == 1) {
        if (target_id == 0) {
            if (rel_type == REL_EXCHANGED) { return "Achaemenid conquest led to administrative and cultural exchange"; }
        }
    }
    # Egyptian→Greek influence
    if (source_id == 0) {
        if (target_id == 3) {
            if (rel_type == REL_INFLUENCED) { return "Egyptian geometry, medicine, and theology transmitted via trade and colonization"; }
        }
    }
    # Greek↔Egyptian syncretism
    if (source_id == 3) {
        if (target_id == 0) {
            if (rel_type == REL_SYNCRETIZED) { return "Hermetic tradition blended Greek philosophy with Egyptian mystery religion"; }
        }
    }
    # Greek→Roman influence
    if (source_id == 3) {
        if (target_id == 12) {
            if (rel_type == REL_INFLUENCED) { return "Greek art, philosophy, and religion adopted wholesale after conquest of Greece"; }
        }
    }
    # Greek absorbed→Roman
    if (source_id == 3) {
        if (target_id == 12) {
            if (rel_type == REL_ABSORBED) { return "Greek cultural identity subsumed into Greco-Roman synthesis post-146 BCE"; }
        }
    }
    # West African→Hip-Hop influence
    if (source_id == 5) {
        if (target_id == 9) {
            if (rel_type == REL_INFLUENCED) { return "Griot oral tradition, call-and-response, and drumming patterns carried via African diaspora"; }
        }
    }
    # Chinese→Japanese influence
    if (source_id == 11) {
        if (target_id == 4) {
            if (rel_type == REL_INFLUENCED) { return "Writing system, Buddhism, Confucian governance transmitted via Korea and direct contact"; }
        }
    }
    # Vedic↔Chinese exchange
    if (source_id == 2) {
        if (target_id == 11) {
            if (rel_type == REL_EXCHANGED) { return "Buddhist transmission via Silk Road, Kushan intermediaries, pilgrim monks"; }
        }
    }
    # Vedic→Tibetan influence
    if (source_id == 2) {
        if (target_id == 15) {
            if (rel_type == REL_INFLUENCED) { return "Vajrayana Buddhism transmitted from Indian monasteries to Tibet via Padmasambhava"; }
        }
    }
    # Arab↔Persian exchange
    if (source_id == 13) {
        if (target_id == 1) {
            if (rel_type == REL_EXCHANGED) { return "Post-conquest synthesis: Arabic script adopted, Persian literature and administration preserved"; }
        }
    }
    # Roman→Byzantine branched
    if (source_id == 12) {
        if (target_id == 19) {
            if (rel_type == REL_BRANCHED_FROM) { return "Eastern Roman continuation: Greek language, Orthodox Christianity, imperial tradition"; }
        }
    }
    # Chinese→Korean influence
    if (source_id == 11) {
        if (target_id == 14) {
            if (rel_type == REL_INFLUENCED) { return "Confucianism, Buddhist monasticism, Chinese script transmitted to Three Kingdoms Korea"; }
        }
    }
    # Jewish↔Arab syncretism
    if (source_id == 18) {
        if (target_id == 13) {
            if (rel_type == REL_SYNCRETIZED) { return "Judeo-Arabic philosophical tradition: Maimonides, Ibn Gabirol, shared Aristotelian commentary"; }
        }
    }
    # Mesopotamian↔Egyptian exchange
    if (source_id == 16) {
        if (target_id == 0) {
            if (rel_type == REL_EXCHANGED) { return "Bronze Age trade: lapis lazuli, cylinder seals, astronomical knowledge exchange"; }
        }
    }
    return 0;
}
