b = bench_new("query/count_active");
bench_batch_start(b);
for (var i = 0; i < N; i = i + 1) { hadara_count_active(); }
bench_batch_stop(b, N);
bench_report(b);

var qbuf = alloc(64 * 8);

b = bench_new("query/coexisting_2026");
bench_batch_start(b);
for (var i = 0; i < N; i = i + 1) { hadara_coexisting_at(2026, qbuf, 64); }
bench_batch_stop(b, N);
bench_report(b);

b = bench_new("query/coexisting_1000bce");
bench_batch_start(b);
for (var i = 0; i < N; i = i + 1) { hadara_coexisting_at(0 - 1000, qbuf, 64); }
bench_batch_stop(b, N);
bench_report(b);

b = bench_new("query/existed_at");
bench_batch_start(b);
for (var i = 0; i < N; i = i + 1) { culture_existed_at(hadara_get(0), 0 - 1000); }
bench_batch_stop(b, N);
bench_report(b);

