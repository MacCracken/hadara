# hadara.bcyr -- Benchmarks for hadara
#
# Benchmarks covering: registry, queries, graph traversal, consumer APIs,
# context generation, evolution tracking.

include "lib/string.cyr"
include "lib/fmt.cyr"
include "lib/alloc.cyr"
include "lib/vec.cyr"
include "lib/str.cyr"
include "lib/math.cyr"
include "lib/syscalls.cyr"
include "lib/bench.cyr"
include "lib/sakshi.cyr"

fn sakshi_span_enter(name, name_len) { return 0; }
fn sakshi_span_exit() { return 0; }

fn prints(s) { syscall(1, 1, s, strlen(s)); return 0; }
fn to_cstr(s) {
    if (s == 0) { return ""; }
    var len = str_len(s);
    var buf = alloc(len + 1);
    memcpy(buf, str_data(s), len);
    store8(buf + len, 0);
    return buf;
}
fn str_builder_add_buf(sb, ptr, len) {
    var i = 0;
    while (i < len) { str_builder_add_byte(sb, load8(ptr + i)); i = i + 1; }
    return 0;
}

include "src/lib.cyr"
include "src/seed.cyr"

var N = 1000;
var b = 0;

alloc_init();
hadara_init();
hadara_seed();

println("=== hadara benchmarks ===");

# ================================================================
# Tier 1: Registry operations
# ================================================================
println("");
println("--- tier 1: registry ---");

b = bench_new("registry/get_by_id");
bench_batch_start(b);
for (var i = 0; i < N; i = i + 1) { hadara_get(9); }
bench_batch_stop(b, N);
bench_report(b);

b = bench_new("registry/len");
bench_batch_start(b);
for (var i = 0; i < N; i = i + 1) { hadara_len(); }
bench_batch_stop(b, N);
bench_report(b);

b = bench_new("registry/culture_accessors");
bench_batch_start(b);
var c = hadara_get(4);
for (var i = 0; i < N; i = i + 1) {
    culture_name_ptr(c);
    culture_status(c);
    culture_time_start(c);
    culture_formality(c);
    culture_values_count(c);
}
bench_batch_stop(b, N);
bench_report(b);

