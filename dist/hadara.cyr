fn culture_directness(c) { return load64(c + CULTURE_DIRECTNESS); }

# --- Status check helpers ---

fn culture_is_active(c) {
    return culture_status(c) == CULTURE_ACTIVE;
}

fn culture_is_living(c) {
    var s = culture_status(c);
    return (s == CULTURE_ACTIVE) + (s == CULTURE_REVIVED);
}

fn culture_existed_at(c, year) {
    var start = culture_time_start(c);
    var end = culture_time_end(c);
    if (year < start) { return 0; }
    if (end == 0) { return 1; }
    if (year > end) { return 0; }
    return 1;
}

