# --- relation.cyr ---

# relation.cyr -- Relationships between cultures
#
# Cultures don't exist in isolation. They influence, syncretize,
# branch from, conflict with, and exchange with each other.
# Each relation is directional and optionally time-bounded.
#
# Sources: Bentley (1993) — interaction classification. Curtin (1984) —
# trade exchange. Stewart & Shaw (1994) — syncretism. Said (1993) — cultural
# conflict. Full bibliography: docs/sources/relations.md

# --- RelationType ---
enum RelationType {
    REL_INFLUENCED = 0;       # source influenced target
    REL_SYNCRETIZED = 1;      # mutual blending (Greek + Egyptian → Hermes Trismegistus)
    REL_BRANCHED_FROM = 2;    # target branched from source
    REL_CONFLICTED = 3;       # cultural conflict or suppression
    REL_EXCHANGED = 4;        # mutual exchange (Silk Road trade cultures)
    REL_ABSORBED = 5;         # source was absorbed into target
    REL_REVIVED_FROM = 6;     # target is a revival of source
}

# --- CultureRelation record layout (heap) ---
# Offset  Field           Size  Description
# 0       source_id       8     CultureId of the source
# 8       target_id       8     CultureId of the target
# 16      relation_type   8     RelationType
# 24      period_start    8     start year of relationship (0 if unknown)
# 32      period_end      8     end year (0 if ongoing/unknown)
# 40      desc_ptr        8     pointer to description string
# 48      desc_len        8     length of description

enum RelationLayout {
    RELATION_SIZE = 56;
    RELATION_SOURCE = 0;
    RELATION_TARGET = 8;
    RELATION_TYPE = 16;
    RELATION_PERIOD_START = 24;
    RELATION_PERIOD_END = 32;
    RELATION_DESC_PTR = 40;
    RELATION_DESC_LEN = 48;
}

fn relation_source(r) { return load64(r + RELATION_SOURCE); }
fn relation_target(r) { return load64(r + RELATION_TARGET); }
fn relation_type(r) { return load64(r + RELATION_TYPE); }
fn relation_period_start(r) { return load64(r + RELATION_PERIOD_START); }
fn relation_period_end(r) { return load64(r + RELATION_PERIOD_END); }

# --- registry.cyr ---

# registry.cyr -- In-memory culture registry
#
# Stores cultures in a heap-allocated array. Lookup by ID, scan
# by status, region, or time period. Consumers call registry
# functions to find cultures; culture records are accessed via
# the accessor functions in culture.cyr.
#
# Max cultures: REGISTRY_MAX (256 default — expandable)

enum RegistryConfig {
    REGISTRY_MAX = 256;
}

var hadara_registry = 0;
var hadara_count = 0;

fn hadara_init() {
    if (hadara_registry == 0) {
        hadara_registry = alloc(REGISTRY_MAX * CULTURE_SIZE);
    }
    hadara_count = 0;
}

# Add a culture to the registry. Returns the CultureId (index).
fn hadara_add(name_ptr, name_len, status, time_start, time_end) {
    var idx = hadara_count;
    if (idx >= REGISTRY_MAX) { return 0 - 1; }
    var c = hadara_registry + idx * CULTURE_SIZE;
    # Zero entire record, then set known fields
    memset(c, 0, CULTURE_SIZE);
    store64(c + CULTURE_ID, idx);
    store64(c + CULTURE_NAME_PTR, name_ptr);
    store64(c + CULTURE_NAME_LEN, name_len);
    store64(c + CULTURE_STATUS, status);
    store64(c + CULTURE_TIME_START, time_start);
    store64(c + CULTURE_TIME_END, time_end);
    # Default display dimensions (5/10 moderate)
    store64(c + CULTURE_FORMALITY, 5);
    store64(c + CULTURE_EXPRESSIVENESS, 5);
    store64(c + CULTURE_INDIVIDUALISM, 5);
    store64(c + CULTURE_DIRECTNESS, 5);
    hadara_count = hadara_count + 1;
    return idx;
}

# Get a culture pointer by ID
fn hadara_get(id) {
    if (id < 0) { return 0; }
    if (id >= hadara_count) { return 0; }
    return hadara_registry + id * CULTURE_SIZE;
}

# Get total culture count
fn hadara_len() {
    return hadara_count;
}

# Set endonym on an existing culture
fn hadara_set_endonym(id, ptr, len) {
    var c = hadara_get(id);
    if (c == 0) { return 0; }
    store64(c + CULTURE_ENDONYM_PTR, ptr);
    store64(c + CULTURE_ENDONYM_LEN, len);
}

# Set display dimensions on an existing culture (formality, expressiveness, individualism, directness)
fn hadara_set_display(id, formality, expressiveness, individualism, directness) {
    var c = hadara_get(id);
    if (c == 0) { return 0; }
    store64(c + CULTURE_FORMALITY, formality);
    store64(c + CULTURE_EXPRESSIVENESS, expressiveness);
    store64(c + CULTURE_INDIVIDUALISM, individualism);
    store64(c + CULTURE_DIRECTNESS, directness);
}

# Set diaspora regions on an existing culture
# Stored as array of string pointers (8 bytes each)
fn hadara_set_diaspora(id, ptr, count) {
    var c = hadara_get(id);
    if (c == 0) { return 0; }
    store64(c + CULTURE_DIASPORA_PTR, ptr);
    store64(c + CULTURE_DIASPORA_COUNT, count);
}

# Set values array on an existing culture
# Values are stored as an array of pointers to null-terminated strings (8 bytes each)
fn hadara_set_values(id, ptr, count) {
    var c = hadara_get(id);
    if (c == 0) { return 0; }
    store64(c + CULTURE_VALUES_PTR, ptr);
    store64(c + CULTURE_VALUES_COUNT, count);
}

# Set practices array on an existing culture
fn hadara_set_practices(id, ptr, count) {
    var c = hadara_get(id);
    if (c == 0) { return 0; }
