# --- culture.cyr ---

# culture.cyr -- Core Culture entity and status types
#
# A Culture is the primary entity in hadara. Everything else
# (practices, art forms, figures, texts, artifacts, relations)
# hangs off a Culture via its CultureId.
#
# Layout: Culture is heap-allocated via registry. Individual
# cultures are accessed by CultureId (integer index).
#
# Sources: Kottak (2019), Ember & Ember (2015) — cultural classification.
# Stearns (2001) — emergence/end dates. Shaw (2000), Brosius (2006),
# Basham (1967), Cunliffe (2018), Chang (2005) — per-culture data.
# Full bibliography: docs/sources/cultures.md

# --- CultureStatus ---
# Where a culture sits on the lifecycle spectrum.
#
# CULTURE_ACTIVE     = 0   Living, practiced today (hip-hop, Persian, Japanese)
# CULTURE_DORMANT    = 1   Not actively practiced but not lost
# CULTURE_REVIVED    = 2   Was dormant, now being restored (Scottish Gaelic, Hawaiian)
# CULTURE_HISTORICAL = 3   Well-documented, no living practitioners in original form
# CULTURE_EXTINCT    = 4   Lost, minimal documentation

enum CultureStatus {
    CULTURE_ACTIVE = 0;
    CULTURE_DORMANT = 1;
    CULTURE_REVIVED = 2;
    CULTURE_HISTORICAL = 3;
    CULTURE_EXTINCT = 4;
}

# --- Culture record layout (heap) ---
# Each culture occupies CULTURE_SIZE bytes in the registry.
#
# Offset  Field                Size   Description
# 0       id                   8      CultureId (integer index)
# 8       name_ptr             8      pointer to name string
# 16      name_len             8      length of name
# 24      endonym_ptr          8      pointer to self-designation string (0 if none)
# 32      endonym_len          8      length of endonym
# 40      status               8      CultureStatus enum value
# 48      geo_roots_ptr        8      pointer to geographic roots array
# 56      geo_roots_count      8      number of geographic roots
# 64      diaspora_ptr         8      pointer to diaspora regions array
# 72      diaspora_count       8      number of diaspora regions
# 80      time_start           8      emergence year (negative for BCE)
# 88      time_end             8      end year (0 if ongoing)
# 96      parent_ptr           8      pointer to parent culture IDs array
# 104     parent_count         8      number of parent cultures
# 112     child_ptr            8      pointer to child culture IDs array
# 120     child_count          8      number of child cultures
# 128     values_ptr           8      pointer to core values array
# 136     values_count         8      number of core values
# 144     practices_ptr        8      pointer to practices array
# 152     practices_count      8      number of practices
# 160     art_forms_ptr        8      pointer to art forms array
# 168     art_forms_count      8      number of art forms
# 176     figures_ptr          8      pointer to key figures array
# 184     figures_count        8      number of key figures
# 192     texts_ptr            8      pointer to sacred texts array
# 200     texts_count          8      number of sacred texts
# 208     artifacts_ptr        8      pointer to material culture array
# 216     artifacts_count      8      number of artifacts
# 224     subcultures_ptr      8      pointer to subculture IDs array
# 232     subcultures_count    8      number of subcultures
# 240     relations_ptr        8      pointer to relations array
# 248     relations_count      8      number of relations
# 256     region_ptr           8      pointer to primary region string
# 264     region_len           8      length of region
# 272     language_ptr         8      pointer to primary language name
# 280     language_len         8      length of language name
# 288     script_ptr           8      pointer to writing system name
# 296     script_len           8      length of script name
# 304     formality            8      display rule: 0-10 (0=informal, 10=formal)
# 312     expressiveness       8      display rule: 0-10 (0=restrained, 10=expressive)
# 320     individualism        8      display rule: 0-10 (0=collective, 10=individual)
# 328     directness           8      display rule: 0-10 (0=indirect, 10=direct)

enum CultureLayout {
    CULTURE_SIZE = 336;
    CULTURE_ID = 0;
    CULTURE_NAME_PTR = 8;
    CULTURE_NAME_LEN = 16;
    CULTURE_ENDONYM_PTR = 24;
    CULTURE_ENDONYM_LEN = 32;
